};

const navItems = [
  {
    group: "Foundation",
    links: [
      { href: "/foundation/colours", label: "Colours" },
      { href: "/foundation/typography", label: "Typography" },
      { href: "/foundation/spacing", label: "Spacing" },
      { href: "/foundation/shadows-radius", label: "Shadows & Radius" },
      { href: "/foundation/materials", label: "Materials" },
      { href: "/foundation/iconography", label: "Iconography" },
    ],
  },
  {
    group: "Components",
    links: [
      { href: "/components/buttons", label: "Buttons" },
      { href: "/components/inputs", label: "Inputs" },
      { href: "/components/chips", label: "Chips" },
      { href: "/components/badges", label: "Badges" },
      { href: "/components/icon-buttons", label: "Icon Buttons" },
      { href: "/components/cards", label: "Cards" },
      { href: "/components/switch-card", label: "Switch Card" },
      { href: "/components/alert-card", label: "Alert Card" },
      { href: "/components/checkbox", label: "Checkbox" },
      { href: "/components/toggle", label: "Toggle" },
      { href: "/components/radio", label: "Radio" },
      { href: "/components/search", label: "Search" },
      { href: "/components/banner", label: "Banner" },
      { href: "/components/backdrop", label: "Backdrop" },
      { href: "/components/dialog", label: "Dialog" },
      { href: "/components/sheets", label: "Sheets" },
      { href: "/components/list", label: "List" },
      { href: "/components/islands", label: "Floating controls" },
      { href: "/components/navigation", label: "Navigation" },
      { href: "/components/toolbar", label: "Toolbar" },
      { href: "/components/progress-bar", label: "Progress bar" },
      { href: "/components/avatar", label: "Avatar" },
      { href: "/components/tabs", label: "Tabs" },
      { href: "/components/bottom-navigation", label: "Bottom navigation" },
      { href: "/components/toast", label: "Toast" },
      { href: "/components/slider", label: "Slider" },
      { href: "/components/select", label: "Select" },
      { href: "/components/accordion", label: "Accordion" },
      { href: "/components/segmented-control", label: "Segmented control" },
      { href: "/components/fab", label: "FAB" },
      { href: "/components/empty-state", label: "Empty state" },
      { href: "/components/spinner", label: "Spinner" },
      { href: "/components/textarea", label: "Textarea" },
      { href: "/components/stepper", label: "Stepper" },
      { href: "/components/skeleton", label: "Skeleton" },
    ],
  },
  {
    group: "Patterns",
    links: [
      { href: "/patterns/dos-donts", label: "Dos & Don'ts" },
      { href: "/patterns/voice-tone", label: "Voice & Tone" },
    ],
  },
  {
    group: "Tooling",
    links: [
      { href: "/tooling/claude-skill", label: "Claude Code skill" },
      { href: "/tooling/atmospheres", label: "Atmospheres" },
    ],
  },
];

function isActive(href: string) {
  if (href === "/") return localPath === "/";
  return localPath.startsWith(href);
}

let activeLabel = 'Overview';
if (currentPath !== '/') {
  for (const group of navItems) {
    for (const link of group.links) {
      if (isActive(link.href)) activeLabel = link.label;
    }
  }
}
