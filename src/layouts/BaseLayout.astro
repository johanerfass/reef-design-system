<script>
// ─── DARK MODE ─────────────────────────────────────────────────────────
const toggle = document.getElementById('themeToggle') as HTMLInputElement;
const logo = document.getElementById('voi-logo')!.querySelector('path')!;

const saved = localStorage.getItem('reef-theme');
let dark = saved === 'dark';

function applyTheme(isDark: boolean) {
  document.documentElement.setAttribute('data-theme', isDark ? 'dark' : '');
  toggle.checked = isDark;
  logo.setAttribute('fill', isDark ? '#ffffff' : '#F26961');
}
applyTheme(dark);

toggle.addEventListener('change', () => {
  dark = toggle.checked;
  localStorage.setItem('reef-theme', dark ? 'dark' : 'light');
  applyTheme(dark);
});

// ─── FROST MODE ────────────────────────────────────────────────────────
const frostToggle = document.getElementById('frostToggle') as HTMLInputElement;
let frosted = localStorage.getItem('reef-frost') !== 'false';

function applyFrost(isFrosted: boolean) {
  document.documentElement.setAttribute('data-frost', isFrosted ? 'true' : '');
  frostToggle.checked = isFrosted;
}
applyFrost(frosted);

frostToggle.addEventListener('change', () => {
  frosted = frostToggle.checked;
  localStorage.setItem('reef-frost', frosted ? 'true' : 'false');
  applyFrost(frosted);
});

// ─── ATMOSPHERE SETTINGS ───────────────────────────────────────────────
const savedAtmCoral = localStorage.getItem('reef-orb-coral');
const savedAtmSky   = localStorage.getItem('reef-orb-sky');
const savedAtmBlur  = localStorage.getItem('reef-orb-blur');
if (savedAtmCoral) document.documentElement.style.setProperty('--orb-coral-opacity', savedAtmCoral);
if (savedAtmSky)   document.documentElement.style.setProperty('--orb-sky-opacity', savedAtmSky);
if (savedAtmBlur)  document.documentElement.style.setProperty('--orb-blur', savedAtmBlur);

// ─── NAV DROPDOWN ──────────────────────────────────────────────────────
const menuBtn = document.getElementById('nav-menu-btn')!;
const navBar   = document.getElementById('nav-bar')!;
const navDropdown = document.getElementById('nav-dropdown')!;
const navOverlay = document.getElementById('nav-overlay')!;

function openNav() {
  navBar.classList.add('nav-open');
  // Fit height to content, cap at viewport
  const contentH = 56 + (navScrollEl.scrollHeight ?? 0);
  navBar.style.height = Math.min(contentH, window.innerHeight - 32) + 'px';
  navDropdown.classList.add('open');
  navOverlay.classList.add('open');
  menuBtn.classList.add('active');
  menuBtn.setAttribute('aria-expanded', 'true');
  navDropdown.setAttribute('aria-hidden', 'false');
  navScrollEl.scrollTop = 0;
}
function closeNav() {
  navBar.classList.remove('nav-open');
  navBar.style.height = '';
  navDropdown.classList.remove('open');
  navOverlay.classList.remove('open');
  menuBtn.classList.remove('active');
  menuBtn.setAttribute('aria-expanded', 'false');
  navDropdown.setAttribute('aria-hidden', 'true');
}

menuBtn.addEventListener('click', () => {
  navDropdown.classList.contains('open') ? closeNav() : openNav();
});
navOverlay.addEventListener('click', closeNav);
document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeNav(); });
navDropdown.querySelectorAll('a').forEach(link => {
  link.addEventListener('click', closeNav);
});

// ─── NAV SCROLL REF ────────────────────────────────────────────────────
const navScrollEl = (navDropdown.querySelector('.nav-mega-inner') as HTMLElement) ?? navDropdown;
</script>

</body>
</html>
