    <circle cx="58" cy="20" r="5" fill="#008545" opacity=".50"/>
    <rect x="24" y="42" width="22" height="4" rx="2" fill="#F26961" opacity=".75"/>
    <rect x="50" y="42" width="44" height="4" rx="2" fill="rgba(40,36,37,.22)"/>
    <rect x="24" y="52" width="15" height="4" rx="2" fill="#ABD1EA" opacity=".85"/>
    <rect x="43" y="52" width="34" height="4" rx="2" fill="rgba(40,36,37,.18)"/>
    <rect x="24" y="62" width="30" height="4" rx="2" fill="rgba(40,36,37,.16)"/>
