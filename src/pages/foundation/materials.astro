---
import BaseLayout from '../../layouts/BaseLayout.astro';

const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="Materials">
  <div class="s-overline">01 — Foundation</div>
  <h1 class="s-title">Materials</h1>
  <p class="s-desc">Materials are the surfaces content sits on. Reef v1.4.0 introduces a full material system: Frost, a liquid-glass family for floating surfaces; Splashes, a living gradient for atmospheric backgrounds; and Asphalt, the deep near-black that grounds the dark theme. Each is a token, not a one-off, so surfaces stay consistent across the rider app, web, and the Business and Ops tools.</p>
  <hr class="s-rule" />

  <!-- ════════════════════════════════════════════════════════════════ -->
  <!-- FROST / LIQUID GLASS                                              -->
  <!-- ════════════════════════════════════════════════════════════════ -->
  <div class="s-overline" style="margin-top:8px">The headline of v1.4.0</div>
  <h2 class="s-title" style="font-size:30px;margin-bottom:12px">Frost · liquid glass</h2>
  <p class="s-desc" style="margin-bottom:32px">A frosted material for any surface that floats above content. On iOS 26 it maps to the native liquid-glass material; on Android and web Reef renders an equivalent frosted layer. The recipe is always the same four properties: a translucent fill, a backdrop blur, a hairline stroke, and a shadow. Three levels tune how much the surface separates from what is behind it.</p>

  <!-- LIVE DEMO — frost over a vivid gradient -->
  <div class="sub-label">Live demo — real backdrop blur</div>
  <p style="font-size:13px;color:var(--content-body-secondary);margin-bottom:20px">Three glass cards floating over a Voi mesh gradient. The blur is real: each card samples and blurs the coral and sky orbs behind it. Toggle the theme to see how the same tokens adapt.</p>

  <div class="frost-stage">
    <div class="frost-stage-bg" aria-hidden="true">
      <span class="frost-blob frost-blob--coral-a"></span>
      <span class="frost-blob frost-blob--coral-b"></span>
      <span class="frost-blob frost-blob--sky-a"></span>
      <span class="frost-blob frost-blob--sky-b"></span>
    </div>
    <div class="frost-demo-group">

      <div class="frost-demo-card material-frost-soft">
        <div class="frost-demo-name">Soft</div>
        <div class="frost-demo-blur">blur 8px</div>
        <div class="frost-demo-token"><code>--fill-frost-soft-enabled</code></div>
        <p class="frost-demo-note">Subtle veil. The background reads clearly through it.</p>
      </div>

      <div class="frost-demo-card material-frost-medium">
        <div class="frost-demo-name">Medium</div>
        <div class="frost-demo-blur">blur 32px</div>
        <div class="frost-demo-token"><code>--fill-frost-medium-enabled</code></div>
        <p class="frost-demo-note">The default for interactive glass. Balanced legibility.</p>
      </div>

      <div class="frost-demo-card material-frost-hard">
        <div class="frost-demo-name">Hard</div>
        <div class="frost-demo-blur">blur 80px</div>
        <div class="frost-demo-token"><code>--fill-frost-hard-enabled</code></div>
        <p class="frost-demo-note">Near-opaque. For sheets and high-attention overlays.</p>
      </div>

    </div>
  </div>

  <!-- ANATOMY -->
  <div class="sub-label" style="margin-top:40px">Anatomy — frost medium</div>
  <p style="font-size:13px;color:var(--content-body-secondary);margin-bottom:20px">Every frosted surface is four stacked properties. The blur is the foundation; fill, stroke, and shadow tune prominence.</p>

  <div class="anatomy-wrap">
    <div class="anatomy-demo">
      <div class="anatomy-surface material-frost-medium">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      </div>
    </div>
    <div class="anatomy-layers">
      <div class="anatomy-row">
        <div class="anatomy-swatch" style="background:rgba(0,0,0,.12);border-radius:4px"></div>
        <div>
          <div class="anatomy-prop">box-shadow</div>
          <div class="anatomy-val"><code>var(--shadow-shallow)</code></div>
          <div class="anatomy-desc">Elevation — makes it readable on any background</div>
        </div>
      </div>
      <div class="anatomy-row">
        <div class="anatomy-swatch" style="background:rgba(255,255,255,.9);border:1px solid rgba(0,0,0,.08);border-radius:4px"></div>
        <div>
          <div class="anatomy-prop">border</div>
          <div class="anatomy-val"><code>1px solid var(--fill-frost-stroke)</code></div>
          <div class="anatomy-desc">Hairline stroke — sharpens the edge against content</div>
        </div>
      </div>
      <div class="anatomy-row">
        <div class="anatomy-swatch" style="background:rgba(255,255,255,.5);border:1px solid rgba(0,0,0,.08);border-radius:4px"></div>
        <div>
          <div class="anatomy-prop">background</div>
          <div class="anatomy-val"><code>var(--fill-frost-medium-enabled)</code></div>
          <div class="anatomy-desc">Fill — controls opacity and tint of the surface</div>
        </div>
      </div>
      <div class="anatomy-row">
        <div class="anatomy-swatch" style="background:linear-gradient(135deg,rgba(255,255,255,.3),rgba(180,180,180,.3));border:1px solid rgba(0,0,0,.08);border-radius:4px"></div>
        <div>
          <div class="anatomy-prop">backdrop-filter</div>
          <div class="anatomy-val"><code>blur(32px)</code></div>
          <div class="anatomy-desc">Blur — the foundation; samples and blurs what's behind</div>
        </div>
      </div>
    </div>
  </div>

  <!-- LEVELS -->
  <div class="sub-label" style="margin-top:40px">Levels — frost soft / medium / hard / solid</div>
  <p style="font-size:13px;color:var(--content-body-secondary);margin-bottom:20px">More fill means less transparency and stronger presence. Choose based on how much the surface needs to stand out from content behind it. Solid is the fallback when there is nothing meaningful to blur.</p>
  <div class="map-stage">
    <div class="map-bg" id="mat-map-1"></div>
    <div class="mat-demo-group">

      <div class="mat-demo-item">
        <div class="mat-chip material-frost-soft">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </div>
        <div class="mat-label">Soft</div>
        <div class="mat-sub">10% · blur 8px</div>
      </div>

      <div class="mat-demo-item">
        <div class="mat-chip material-frost-medium">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </div>
        <div class="mat-label">Medium</div>
        <div class="mat-sub">50% · blur 32px</div>
      </div>

      <div class="mat-demo-item">
        <div class="mat-chip material-frost-hard">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </div>
        <div class="mat-label">Hard</div>
        <div class="mat-sub">70% · blur 80px</div>
      </div>

      <div class="mat-demo-item">
        <div class="mat-chip material-solid">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </div>
        <div class="mat-label">Solid</div>
        <div class="mat-sub">100% · no blur</div>
      </div>

    </div>
  </div>

  <!-- FIGMA EFFECT + ELEVATION STYLES -->
  <div class="sub-label" style="margin-top:40px">Figma styles — new in v1.4.0</div>
  <p style="font-size:13px;color:var(--content-body-secondary);margin-bottom:20px">In Figma the material ships as two families of named styles, so designers apply glass the same way engineers do. Effect styles carry just the blur; elevation styles add a deep shadow below for surfaces that float free of any edge.</p>
  <div class="grid-2" style="gap:16px">
    <div class="card card-sm" style="border-radius:16px">
      <div class="fx-head">
        <span class="fx-kind">Effect styles</span>
        <span style="font-size:11px;color:var(--content-body-tertiary)">frosted blur only</span>
      </div>
      <p style="font-size:12px;color:var(--content-body-secondary);line-height:1.5;margin-bottom:14px">Background blur with no shadow. Use when the glass sits flush against a sheet edge or another surface and does not need to read as lifted.</p>
      <ul class="fx-list">
        <li><code class="token">frost/soft</code><span>blur 8px</span></li>
        <li><code class="token">frost/medium</code><span>blur 32px</span></li>
        <li><code class="token">frost/hard</code><span>blur 80px</span></li>
      </ul>
    </div>
    <div class="card card-sm" style="border-radius:16px">
      <div class="fx-head">
        <span class="fx-kind">Elevation styles</span>
        <span style="font-size:11px;color:var(--content-body-tertiary)">blur + deep shadow</span>
      </div>
      <p style="font-size:12px;color:var(--content-body-secondary);line-height:1.5;margin-bottom:14px">The same blur plus a soft shadow cast below, for floating glass — navigation islands, toolbars, and cards that hover over the map.</p>
      <ul class="fx-list">
        <li><code class="token">frost-deep-below/soft</code><span>8px + shadow</span></li>
        <li><code class="token">frost-deep-below/medium</code><span>32px + shadow</span></li>
        <li><code class="token">frost-deep-below/hard</code><span>80px + shadow</span></li>
      </ul>
    </div>
  </div>

  <!-- ICON BUTTONS -->
  <div class="sub-label" style="margin-top:40px">Applied to icon buttons</div>
  <p style="font-size:13px;color:var(--content-body-secondary);margin-bottom:20px">Icon buttons inherit the frosted material. Four sizes — sm (40px), md (48px), lg (64px), xl (72px) — combine with <code>material-frost-soft/medium/hard</code>.</p>
  <div class="map-stage">
    <div class="map-bg" id="mat-map-2"></div>
    <div class="icon-btn-group">
      <div class="icon-btn-col">
        <button class="icon-btn icon-btn-sm material-frost-medium" aria-label="Add">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        </button>
        <div class="mat-label">sm · 40px</div>
        <div class="mat-sub">icon-btn-sm</div>
      </div>
      <div class="icon-btn-col">
        <button class="icon-btn icon-btn-md material-frost-medium" aria-label="Map">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"/><line x1="8" y1="2" x2="8" y2="18"/><line x1="16" y1="6" x2="16" y2="22"/></svg>
        </button>
        <div class="mat-label">md · 48px</div>
        <div class="mat-sub">icon-btn-md</div>
      </div>
      <div class="icon-btn-col">
        <button class="icon-btn icon-btn-lg material-frost-medium" aria-label="Profile">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </button>
        <div class="mat-label">lg · 64px</div>
        <div class="mat-sub">icon-btn-lg</div>
      </div>
      <div class="icon-btn-col">
        <button class="icon-btn icon-btn-xl material-frost-medium" aria-label="Ticket">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-4 0v2"/><line x1="12" y1="12" x2="12" y2="16"/><line x1="10" y1="14" x2="14" y2="14"/></svg>
        </button>
        <div class="mat-label">xl · 72px</div>
        <div class="mat-sub">icon-btn-xl</div>
      </div>
      <div class="icon-btn-col">
        <button class="icon-btn icon-btn-lg material-frost-soft" aria-label="Search">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        </button>
        <div class="mat-label">Soft</div>
        <div class="mat-sub">material-frost-soft</div>
      </div>
      <div class="icon-btn-col">
        <button class="icon-btn icon-btn-lg material-frost-hard" aria-label="Close">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
        <div class="mat-label">Hard</div>
        <div class="mat-sub">material-frost-hard</div>
      </div>
    </div>
  </div>

  <!-- CARDS -->
  <div class="sub-label" style="margin-top:40px">Applied to cards</div>
  <p style="font-size:13px;color:var(--content-body-secondary);margin-bottom:20px">Frosted cards float above the map and carry full content. Use <code>frost-medium</code> for interactive cards, <code>frost-hard</code> for prominent overlays and sheets.</p>
  <div class="map-stage map-stage--tall">
    <div class="map-bg" id="mat-map-3"></div>
    <div class="card-demo-group">

      <!-- Medium card -->
      <div class="card card-sm material-frost-medium mat-card">
        <div class="mat-card-label">frost-medium</div>
        <div class="mat-card-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"/><line x1="8" y1="2" x2="8" y2="18"/><line x1="16" y1="6" x2="16" y2="22"/></svg>
        </div>
        <div class="mat-card-title">Start ride</div>
        <div class="mat-card-body">Scan the QR code on any scooter or e-bike to unlock.</div>
        <button class="btn btn-contrast btn-sm" style="width:100%;margin-top:4px">Scan</button>
      </div>

      <!-- Hard card -->
      <div class="card card-sm material-frost-hard mat-card">
        <div class="mat-card-label">frost-hard</div>
        <div class="mat-card-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        </div>
        <div class="mat-card-title">Slow zone ahead</div>
        <div class="mat-card-body">Speed limit 10 km/h applies from here. Ride carefully.</div>
        <div style="display:flex;gap:8px;margin-top:4px">
          <button class="btn btn-outlined btn-sm" style="flex:1">Dismiss</button>
          <button class="btn btn-contrast btn-sm" style="flex:1">Got it</button>
        </div>
      </div>

      <!-- Solid card -->
      <div class="card card-sm material-solid mat-card">
        <div class="mat-card-label">solid</div>
        <div class="mat-card-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-4 0v2"/><line x1="12" y1="12" x2="12" y2="16"/><line x1="10" y1="14" x2="14" y2="14"/></svg>
        </div>
        <div class="mat-card-title">Ride summary</div>
        <div class="mat-card-body">2.4 km · 13 min · Saved 28%</div>
        <button class="btn btn-contrast btn-sm" style="width:100%;margin-top:4px">Done</button>
      </div>

    </div>
  </div>

  <!-- TOKENS -->
  <div class="sub-label" style="margin-top:40px">Frost tokens</div>
  <table class="prop-table">
    <thead><tr><th>Token</th><th>Light</th><th>Dark</th><th>Blur</th><th>Use</th></tr></thead>
    <tbody>
      <tr><td><code>--fill-frost-soft-enabled</code></td><td>white 10%</td><td>grey 10%</td><td><code>8px</code></td><td>Subtle overlays, secondary non-interactive surfaces</td></tr>
      <tr><td><code>--fill-frost-medium-enabled</code></td><td>white 50%</td><td>grey 50%</td><td><code>32px</code></td><td>Icon buttons, interactive cards, navigation islands</td></tr>
      <tr><td><code>--fill-frost-hard-enabled</code></td><td>white 70%</td><td>grey 70%</td><td><code>80px</code></td><td>Prominent cards, overlays, bottom sheets</td></tr>
      <tr><td><code>--fill-frost-stroke</code></td><td>white 60%</td><td>white 10%</td><td>—</td><td>Hairline border on every frosted surface</td></tr>
    </tbody>
  </table>
  <p style="font-size:12px;color:var(--content-body-tertiary);margin-top:12px"><code>fill/frost-stroke</code> is new in v1.4.0. It is white 60% in the light theme and drops to white 10% in dark, so the edge stays a faint catch of light rather than a hard line.</p>

  <!-- CODE -->
  <div class="sub-label" style="margin-top:40px">Code</div>
  <div class="code-block"><pre><span class="c-comment">/* Apply to any element */</span>
<span class="c-tag">.element</span> {"{"}
  <span class="c-attr">background:</span> <span class="c-value">var(--fill-frost-medium-enabled)</span>;
  <span class="c-attr">backdrop-filter:</span> <span class="c-value">blur(32px)</span>;
  <span class="c-attr">-webkit-backdrop-filter:</span> <span class="c-value">blur(32px)</span>;
  <span class="c-attr">border:</span> <span class="c-value">1px solid var(--fill-frost-stroke)</span>;
  <span class="c-attr">box-shadow:</span> <span class="c-value">var(--shadow-shallow)</span>;
{"}"}

<span class="c-comment">/* Utility classes */</span>
<span class="c-tag">&lt;div</span> <span class="c-attr">class</span>=<span class="c-str">"material-frost-soft"</span><span class="c-tag">&gt;</span>...<span class="c-tag">&lt;/div&gt;</span>
<span class="c-tag">&lt;div</span> <span class="c-attr">class</span>=<span class="c-str">"material-frost-medium"</span><span class="c-tag">&gt;</span>...<span class="c-tag">&lt;/div&gt;</span>
<span class="c-tag">&lt;div</span> <span class="c-attr">class</span>=<span class="c-str">"material-frost-hard"</span><span class="c-tag">&gt;</span>...<span class="c-tag">&lt;/div&gt;</span>
<span class="c-tag">&lt;div</span> <span class="c-attr">class</span>=<span class="c-str">"material-solid"</span><span class="c-tag">&gt;</span>...<span class="c-tag">&lt;/div&gt;</span>

<span class="c-comment">/* iOS 26 — use the native liquid glass material */</span>
<span class="c-comment">/* SwiftUI: .glassBackgroundEffect() */</span>
<span class="c-comment">/* UIKit:   UIGlassEffect() / UIBlurEffect(.systemMaterial) */</span></pre></div>

  <!-- RULES -->
  <div class="sub-label" style="margin-top:40px">Usage rules</div>
  <div class="grid-2" style="gap:16px">
    <div class="card card-sm" style="border-radius:16px">
      <div style="font-size:12px;font-weight:600;color:var(--alert-success);margin-bottom:8px">✓ Do</div>
      <ul style="font-size:13px;color:var(--content-body-secondary);display:flex;flex-direction:column;gap:6px;padding-left:16px">
        <li>Apply to any surface that floats above real content — map, image, gradient</li>
        <li>Use <code class="token">frost-medium</code> as the default for interactive components</li>
        <li>Use <code class="token">frost-hard</code> for sheets, prominent overlays, and high-attention surfaces</li>
        <li>Use <code class="token">frost-soft</code> for decorative or secondary non-interactive layers</li>
        <li>Reach for an elevation style when the glass floats free; an effect style when it sits flush</li>
        <li>On iOS 26, use native liquid glass — the OS handles adaptation automatically</li>
      </ul>
    </div>
    <div class="card card-sm" style="border-radius:16px">
      <div style="font-size:12px;font-weight:600;color:var(--alert-error);margin-bottom:8px">✗ Don't</div>
      <ul style="font-size:13px;color:var(--content-body-secondary);display:flex;flex-direction:column;gap:6px;padding-left:16px">
        <li>Place frosted surfaces on flat colour backgrounds — there is nothing to blur</li>
        <li>Nest frosted surfaces inside other frosted surfaces</li>
        <li>Apply <code class="token">backdrop-filter</code> to full-screen backgrounds — severe performance hit</li>
        <li>Use iOS liquid-glass APIs on Android or web</li>
        <li>Omit the <code class="token">-webkit-backdrop-filter</code> prefix — Safari requires it</li>
      </ul>
    </div>
  </div>

  <hr class="s-rule" style="margin-top:56px" />

  <!-- ════════════════════════════════════════════════════════════════ -->
  <!-- SPLASHES                                                          -->
  <!-- ════════════════════════════════════════════════════════════════ -->
  <div class="s-overline" style="margin-top:8px">New in v1.4.0</div>
  <h2 class="s-title" style="font-size:30px;margin-bottom:12px">Splashes <span class="beta-tag" style="font-size:11px;vertical-align:middle">Beta</span></h2>
  <p class="s-desc" style="margin-bottom:32px">Splashes is Voi's animated gradient material: a slow, living mesh of coral and sky orbs drifting over a calm sand base. It gives marketing surfaces, hero sections, and splash screens a sense of quiet motion without pulling focus. It is the surface our frosted glass loves to sit on, because there is always something soft moving behind the blur.</p>

  <div class="splash-feature">
    <a href={`${BASE}/tooling/splashes`} class="splash-preview" aria-label="Open the Splashes tool">
      <span class="splash-orb splash-orb--coral-a"></span>
      <span class="splash-orb splash-orb--coral-b"></span>
      <span class="splash-orb splash-orb--sky-a"></span>
      <span class="splash-orb splash-orb--sky-b"></span>
      <span class="splash-preview-tag">Living gradient</span>
    </a>
    <div class="splash-copy">
      <p style="font-size:13px;color:var(--content-body-secondary);line-height:1.6;margin-bottom:8px">Splashes is still settling. It is built for atmospheric, low-density surfaces — not yet for dense product UI. Defaults and the snippet API may change before it leaves beta.</p>
      <p style="font-size:13px;color:var(--content-body-secondary);line-height:1.6;margin-bottom:20px">The Splashes tool lets you tune orb density, opacity, blur, and motion, then copy a ready-made snippet. Coral stays the brand accent, so keep it sparing and let sand and sky carry the canvas.</p>
      <a href={`${BASE}/tooling/splashes`} class="btn btn-contrast btn-md" style="text-decoration:none">Open the Splashes tool →</a>
    </div>
  </div>

  <hr class="s-rule" style="margin-top:56px" />

  <!-- ════════════════════════════════════════════════════════════════ -->
  <!-- ASPHALT                                                           -->
  <!-- ════════════════════════════════════════════════════════════════ -->
  <div class="s-overline" style="margin-top:8px">New in v1.4.0</div>
  <h2 class="s-title" style="font-size:30px;margin-bottom:12px">Asphalt</h2>
  <p class="s-desc" style="margin-bottom:32px">Asphalt is the deep, near-black material the dark theme is built on. It is the ground floor: the base surface every other dark surface, shadow, and frosted layer is measured against. Warmer than pure black, it keeps the dark theme feeling like Voi rather than a void, and gives glass something rich to blur.</p>

  <div class="grid-2" style="gap:16px;align-items:stretch">
    <div class="asphalt-swatch">
      <div>
        <div class="asphalt-swatch-name">Asphalt</div>
        <div class="asphalt-swatch-hex">#161314</div>
      </div>
    </div>
    <div class="card card-sm" style="border-radius:16px;display:flex;flex-direction:column;justify-content:center">
      <div class="sub-label" style="padding-top:0;margin-bottom:14px">Token</div>
      <table class="prop-table" style="margin:0">
        <tbody>
          <tr><td><code>--neutral-asphalt</code></td><td>Primitive — <code>#161314</code></td></tr>
          <tr><td><code>--surface-base-enabled</code></td><td>Maps to asphalt in dark</td></tr>
        </tbody>
      </table>
      <p style="font-size:12px;color:var(--content-body-tertiary);margin-top:14px;line-height:1.5">In the light theme <code class="token">--surface-base-enabled</code> resolves to pearl; in dark it resolves to asphalt. Use the semantic surface token in product, not the raw primitive.</p>
    </div>
  </div>

</BaseLayout>

