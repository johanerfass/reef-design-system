---

<BaseLayout title="Iconography">
  <div class="s-overline">01 — Foundation</div>
  <h1 class="s-title">Iconography</h1>
  <p class="s-desc">Web icons 24px — sourced from the Voi Frontify brand library. 958 icons across 5 collections. All icons are 24×24px SVG, monochrome, rendered at 1× on all surfaces.</p>
  <hr class="s-rule" />

  <!-- STATS + USAGE RULES -->
  <div class="grid-2" style="gap:16px;margin-bottom:40px">
    <div class="card card-sm" style="border-radius:16px">
      <p style="font-size:12px;font-weight:600;color:var(--content-body-tertiary);margin-bottom:12px;letter-spacing:.01em">Library stats</p>
      <div style="display:flex;flex-direction:column;gap:8px;font-size:12px">
        <div style="display:flex;justify-content:space-between"><span style="color:var(--content-body-secondary)">Total icons</span><code class="token">958</code></div>
        <div style="display:flex;justify-content:space-between"><span style="color:var(--content-body-secondary)">Collections</span><code class="token">5</code></div>
        <div style="display:flex;justify-content:space-between"><span style="color:var(--content-body-secondary)">Size</span><code class="token">24 × 24 px</code></div>
        <div style="display:flex;justify-content:space-between"><span style="color:var(--content-body-secondary)">Format</span><code class="token">SVG monochrome</code></div>
        <div style="display:flex;justify-content:space-between"><span style="color:var(--content-body-secondary)">Source</span><code class="token">Frontify · Web icons 24px</code></div>
      </div>
    </div>
    <div class="card card-sm" style="border-radius:16px">
      <p style="font-size:12px;font-weight:600;color:var(--content-body-tertiary);margin-bottom:12px;letter-spacing:.01em">Collections</p>
      <div style="display:flex;flex-direction:column;gap:8px;font-size:12px">
        {[
          { name: 'User icons', count: '~200' },
          { name: 'Arrows', count: '~80' },
          { name: 'Animated loops', count: '~40' },
          { name: 'Interactive icons', count: '~60' },
          { name: 'Map icons', count: '~24' },
        ].map(c => (
          <div style="display:flex;justify-content:space-between">
            <span style="color:var(--content-body-secondary)">{c.name}</span>
            <code class="token">{c.count}</code>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- USAGE RULES -->
  <div class="card" style="margin-bottom:40px;border-radius:20px;background:rgba(242,105,97,.05);box-shadow:none;border:1px solid rgba(242,105,97,.2)">
    <p style="font-size:14px;font-weight:600;color:var(--supporting-brick);margin-bottom:12px">Usage rules</p>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;font-size:13px;color:var(--content-body-secondary);line-height:1.6">
      <div>
        <strong style="color:var(--content-body-primary)">Always 24px</strong><br/>
        Icons are designed at 24×24px. Do not scale to arbitrary sizes — use 16px or 32px variants if available.
      </div>
      <div>
        <strong style="color:var(--content-body-primary)">Inherit colour</strong><br/>
        Icons should inherit text colour via <code class="token">currentColor</code>. Never hardcode a colour on an icon directly.
      </div>
      <div>
        <strong style="color:var(--content-body-primary)">Paired with label</strong><br/>
        Icons alone are not accessible. Always pair with a visible label or <code class="token">aria-label</code> on the parent.
      </div>
      <div>
        <strong style="color:var(--content-body-primary)">No coral icons</strong><br/>
        Do not use Coral (#F26961) on icons except for brand moments. Use Tire or semantic status colours.
      </div>
    </div>
  </div>

  <!-- SEARCH -->
  <div class="icon-search-wrap" style="margin-bottom:32px">
    <svg style="position:absolute;left:14px;top:50%;transform:translateY(-50%);width:18px;height:18px;color:var(--content-icon-primary);pointer-events:none" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    <input class="icon-search-input" id="icon-search" type="search" placeholder="Search 59 shown icons by name…" autocomplete="off" />
  </div>

  <!-- MAP COLLECTION -->
  <div class="sub-label" id="section-map">Map icons <span style="font-size:11px;font-weight:400;color:var(--content-body-tertiary);margin-left:8px">{mapIcons.length} shown</span></div>
  <div class="icon-grid" id="grid-map">
    {mapIcons.map(icon => (
      <div class="icon-cell" data-name={icon.name}>
        <img src={u(icon.hash)} alt={icon.name} width="24" height="24" loading="lazy" />
        <span class="icon-cell-name">{icon.name}</span>
      </div>
    ))}
  </div>

  <!-- ARROWS COLLECTION -->
  <div class="sub-label" id="section-arrows">Arrow icons <span style="font-size:11px;font-weight:400;color:var(--content-body-tertiary);margin-left:8px">{arrowIcons.length} shown</span></div>
  <div class="icon-grid" id="grid-arrows">
    {arrowIcons.map(icon => (
      <div class="icon-cell" data-name={icon.name}>
        <img src={u(icon.hash)} alt={icon.name} width="24" height="24" loading="lazy" />
        <span class="icon-cell-name">{icon.name}</span>
      </div>
    ))}
  </div>

  <!-- GENERAL -->
  <div class="sub-label" id="section-general">General <span style="font-size:11px;font-weight:400;color:var(--content-body-tertiary);margin-left:8px">{generalIcons.length} shown</span></div>
  <div class="icon-grid" id="grid-general">
    {generalIcons.map(icon => (
      <div class="icon-cell" data-name={icon.name}>
        <img src={u(icon.hash)} alt={icon.name} width="24" height="24" loading="lazy" />
        <span class="icon-cell-name">{icon.name}</span>
      </div>
    ))}
  </div>

  <p style="font-size:12px;color:var(--content-body-tertiary);margin-top:8px">
    Showing 59 of 958 icons. Full library at
    <a href="https://brand.voi.com/hub/3" target="_blank" rel="noopener" style="color:var(--supporting-brick)">brand.voi.com</a> → Web icons 24px.
  </p>
</BaseLayout>

<script>
const input = document.getElementById('icon-search') as HTMLInputElement;
const allCells = document.querySelectorAll<HTMLElement>('.icon-cell');

input?.addEventListener('input', () => {
  const q = input.value.toLowerCase().trim();
  allCells.forEach(cell => {
    const name = cell.dataset.name ?? '';
    cell.style.display = (!q || name.includes(q)) ? '' : 'none';
  });
});
</script>
