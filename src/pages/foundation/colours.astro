---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Colours">
  <div class="s-overline">01 — Foundation</div>
  <h1 class="s-title">The palette</h1>
  <p class="s-desc">Coral is a brand colour, not a CTA. Primary actions are Tire. One accent per screen. Colour is punctuation, not wallpaper.</p>
  <hr class="s-rule" />

  <div class="palette-group">
    <div class="palette-group-title">Brand core</div>
    <div class="palette-grid">
      <div class="swatch"><div class="swatch-color" style="background:#f26961"></div><div class="swatch-info"><div class="swatch-name">Coral</div><div class="swatch-hex">#f26961 · brand only, never CTA</div></div></div>
      <div class="swatch"><div class="swatch-color" style="background:#282425"></div><div class="swatch-info"><div class="swatch-name">Tire</div><div class="swatch-hex">#282425 · primary CTA</div></div></div>
      <div class="swatch"><div class="swatch-color" style="background:#faf4ec"></div><div class="swatch-info"><div class="swatch-name">Sand</div><div class="swatch-hex">#faf4ec · hero/gradient base</div></div></div>
      <div class="swatch"><div class="swatch-color" style="background:#f8b3ad"></div><div class="swatch-info"><div class="swatch-name">Rose</div><div class="swatch-hex">#f8b3ad · dark brand fill</div></div></div>
    </div>
  </div>

  <div class="palette-group">
    <div class="palette-group-title">Coral family</div>
    <div class="palette-grid">
      <div class="swatch"><div class="swatch-color" style="background:#ffdcd9"></div><div class="swatch-info"><div class="swatch-name">Pink</div><div class="swatch-hex">#ffdcd9</div></div></div>
      <div class="swatch"><div class="swatch-color" style="background:#f8b3ad"></div><div class="swatch-info"><div class="swatch-name">Rose</div><div class="swatch-hex">#f8b3ad</div></div></div>
      <div class="swatch"><div class="swatch-color" style="background:#f58e87"></div><div class="swatch-info"><div class="swatch-name">Salmon</div><div class="swatch-hex">#f58e87</div></div></div>
      <div class="swatch"><div class="swatch-color" style="background:#f26961"></div><div class="swatch-info"><div class="swatch-name">Coral</div><div class="swatch-hex">#f26961</div></div></div>
      <div class="swatch"><div class="swatch-color" style="background:#d04740"></div><div class="swatch-info"><div class="swatch-name">Brick</div><div class="swatch-hex">#d04740 · WCAG-safe coral</div></div></div>
      <div class="swatch"><div class="swatch-color" style="background:#8d0601"></div><div class="swatch-info"><div class="swatch-name">Cherry</div><div class="swatch-hex">#8d0601</div></div></div>
      <div class="swatch"><div class="swatch-color" style="background:#500402"></div><div class="swatch-info"><div class="swatch-name">Chestnut</div><div class="swatch-hex">#500402 · Voi+ surface</div></div></div>
    </div>
  </div>

  <div class="palette-group">
    <div class="palette-group-title">Sky family</div>
    <div class="palette-grid">
      <div class="swatch"><div class="swatch-color" style="background:#abd1ea"></div><div class="swatch-info"><div class="swatch-name">Sky</div><div class="swatch-hex">#abd1ea</div></div></div>
      <div class="swatch"><div class="swatch-color" style="background:#89abc8"></div><div class="swatch-info"><div class="swatch-name">Overcast</div><div class="swatch-hex">#89abc8</div></div></div>
      <div class="swatch"><div class="swatch-color" style="background:#6785a5"></div><div class="swatch-info"><div class="swatch-name">Thunder</div><div class="swatch-hex">#6785a5</div></div></div>
      <div class="swatch"><div class="swatch-color" style="background:#455f85"></div><div class="swatch-info"><div class="swatch-name">Sea</div><div class="swatch-hex">#455f85 · filter active</div></div></div>
      <div class="swatch"><div class="swatch-color" style="background:#243860"></div><div class="swatch-info"><div class="swatch-name">Space</div><div class="swatch-hex">#243860</div></div></div>
    </div>
  </div>

  <div class="palette-group">
    <div class="palette-group-title">Neutrals</div>
    <div class="palette-grid">
      <div class="swatch"><div class="swatch-color" style="background:#f2f2f6"></div><div class="swatch-info"><div class="swatch-name">Pearl</div><div class="swatch-hex">#f2f2f6 · base bg</div></div></div>
      <div class="swatch"><div class="swatch-color" style="background:#edebed"></div><div class="swatch-info"><div class="swatch-name">Chalk</div><div class="swatch-hex">#edebed</div></div></div>
      <div class="swatch"><div class="swatch-color" style="background:#e8e4e5"></div><div class="swatch-info"><div class="swatch-name">Shell</div><div class="swatch-hex">#e8e4e5</div></div></div>
      <div class="swatch"><div class="swatch-color" style="background:#d0cccd"></div><div class="swatch-info"><div class="swatch-name">Marble</div><div class="swatch-hex">#d0cccd</div></div></div>
      <div class="swatch"><div class="swatch-color" style="background:#b8b4b5"></div><div class="swatch-info"><div class="swatch-name">Granite</div><div class="swatch-hex">#b8b4b5</div></div></div>
      <div class="swatch"><div class="swatch-color" style="background:#989495"></div><div class="swatch-info"><div class="swatch-name">Gravel</div><div class="swatch-hex">#989495</div></div></div>
      <div class="swatch"><div class="swatch-color" style="background:#787475"></div><div class="swatch-info"><div class="swatch-name">Slate</div><div class="swatch-hex">#787475</div></div></div>
      <div class="swatch"><div class="swatch-color" style="background:#585455"></div><div class="swatch-info"><div class="swatch-name">Tarmac</div><div class="swatch-hex">#585455</div></div></div>
      <div class="swatch"><div class="swatch-color" style="background:#403c3d"></div><div class="swatch-info"><div class="swatch-name">Basalt</div><div class="swatch-hex">#403c3d</div></div></div>
      <div class="swatch"><div class="swatch-color" style="background:#322e2f"></div><div class="swatch-info"><div class="swatch-name">Graphite</div><div class="swatch-hex">#322e2f</div></div></div>
      <div class="swatch"><div class="swatch-color" style="background:#1f1c1d"></div><div class="swatch-info"><div class="swatch-name">Rubber</div><div class="swatch-hex">#1f1c1d</div></div></div>
      <div class="swatch"><div class="swatch-color" style="background:#161314"></div><div class="swatch-info"><div class="swatch-name">Asphalt</div><div class="swatch-hex">#161314 · dark base</div></div></div>
    </div>
  </div>

  <div class="palette-group">
    <div class="palette-group-title">Status</div>
    <div class="palette-grid">
      <div class="swatch"><div class="swatch-color" style="background:#008545"></div><div class="swatch-info"><div class="swatch-name">Success</div><div class="swatch-hex">#008545</div></div></div>
      <div class="swatch"><div class="swatch-color" style="background:#ffb100"></div><div class="swatch-info"><div class="swatch-name">Warning</div><div class="swatch-hex">#ffb100</div></div></div>
      <div class="swatch"><div class="swatch-color" style="background:#ed0a02"></div><div class="swatch-info"><div class="swatch-name">Error</div><div class="swatch-hex">#ed0a02</div></div></div>
      <div class="swatch"><div class="swatch-color" style="background:#0075db"></div><div class="swatch-info"><div class="swatch-name">Info</div><div class="swatch-hex">#0075db</div></div></div>
      <div class="swatch"><div class="swatch-color" style="background:#c802e9"></div><div class="swatch-info"><div class="swatch-name">Mandatory</div><div class="swatch-hex">#c802e9</div></div></div>
      <div class="swatch"><div class="swatch-color" style="background:#52d1dc"></div><div class="swatch-info"><div class="swatch-name">Pending</div><div class="swatch-hex">#52d1dc</div></div></div>
    </div>
  </div>

  <div class="card" style="border-radius:24px;background:rgba(242,105,97,.06);box-shadow:none;border:1px solid rgba(242,105,97,.2)">
    <p style="font-size:14px;font-weight:600;color:var(--supporting-brick);margin-bottom:4px">Coral accessibility rule</p>
    <p style="font-size:13px;color:var(--content-body-secondary);line-height:1.6">Coral (#F26961) <strong>fails WCAG AA</strong> on white for small text. Use Brick (#D04740) for text links, icons below 24px, and small button labels. The React <code style="font-family:monospace;font-size:12px">accent</code> variant does this automatically at <code style="font-family:monospace;font-size:12px">small</code> size.</p>
  </div>
</BaseLayout>
