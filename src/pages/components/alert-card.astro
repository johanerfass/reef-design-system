---
import BaseLayout from '../../layouts/BaseLayout.astro';

// The v1.4.0 alert icon set — filled colour badges with white glyphs.
const badges = {
  success: `<svg class="alert-badge" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5" fill="var(--alert-success)"/><path d="M8 12.4l2.8 2.8L16.4 9.6" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  info: `<svg class="alert-badge" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="9.5" fill="var(--alert-info)"/><circle cx="12" cy="7.9" r="1.25" fill="#fff"/><rect x="10.85" y="10.4" width="2.3" height="6.4" rx="1.15" fill="#fff"/></svg>`,
  warning: `<svg class="alert-badge" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M8 2.6h8L21.4 8v8L16 21.4H8L2.6 16V8z" fill="var(--alert-warning)"/><rect x="10.85" y="6.4" width="2.3" height="7.2" rx="1.15" fill="#fff"/><circle cx="12" cy="16.6" r="1.3" fill="#fff"/></svg>`,
  error: `<svg class="alert-badge" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M10.7 3.4a1.5 1.5 0 0 1 2.6 0l8 14a1.5 1.5 0 0 1-1.3 2.25H4a1.5 1.5 0 0 1-1.3-2.25z" fill="var(--alert-error)"/><rect x="10.85" y="8.4" width="2.3" height="6.2" rx="1.15" fill="#fff"/><circle cx="12" cy="17.3" r="1.25" fill="#fff"/></svg>`,
  mandatory: `<svg class="alert-badge" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2.5 19.5 5.5V11c0 4.8-3.2 8.6-7.5 10.5C7.7 19.6 4.5 15.8 4.5 11V5.5z" fill="var(--alert-mandatory)"/><rect x="8.7" y="11.1" width="6.6" height="5.2" rx="1.4" fill="#fff"/><path d="M9.9 11.1V9.7a2.1 2.1 0 0 1 4.2 0v1.4" stroke="#fff" stroke-width="1.4" fill="none"/></svg>`,
};

const types = [
  { key: 'success',   label: 'Success',   title: 'Ride ended',            body: 'Parked correctly. €0.50 discount applied.' },
  { key: 'info',      label: 'Info',      title: 'New speed zone',        body: 'Max 15 km/h in the pedestrian area ahead.' },
  { key: 'warning',   label: 'Warning',   title: 'Battery at 12%',        body: 'This scooter may not reach your destination.' },
  { key: 'error',     label: 'Error',     title: 'No signal here',        body: 'Try walking a few metres to end your ride.' },
  { key: 'mandatory', label: 'Mandatory', title: 'Verification required', body: 'Verify your identity to ride in this city.' },
];

const closeSvg = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>`;
---

<BaseLayout title="Alert Card">
  <div class="s-overline">02 — Components</div>
  <h1 class="s-title">Alert card</h1>
  <p class="s-desc">Inline contextual feedback tied to a specific piece of content or action. Five semantic types — success, info, warning, error, and mandatory — in two styles: transparent (tint over the surface) and solid (opaque fill). Always include badge + title + body.</p>
  <hr class="s-rule" />

  <div class="sub-label">Styles — transparent vs solid bg</div>
  <div class="alert-grid">
    <div class="alert-grid-head"></div>
    <div class="alert-grid-head">Transparent</div>
    <div class="alert-grid-head">Solid bg</div>
    {types.map(t => (
      <>
        <div class="alert-grid-label">{t.label}</div>
        <div class="alert-card-cell">
          <div class={`alert-card alert-card-${t.key}`} style="margin-bottom:0">
            <Fragment set:html={badges[t.key]} />
            <div class="alert-card-content"><div class="title">{t.title}</div><div class="body">{t.body}</div></div>
            <button class="alert-card-x" aria-label="Dismiss"><Fragment set:html={closeSvg} /></button>
          </div>
        </div>
        <div class="alert-card-cell">
          <div class={`alert-card alert-card--solid alert-card-${t.key}`} style="margin-bottom:0">
            <Fragment set:html={badges[t.key]} />
            <div class="alert-card-content"><div class="title">{t.title}</div><div class="body">{t.body}</div></div>
            <button class="alert-card-x" aria-label="Dismiss"><Fragment set:html={closeSvg} /></button>
          </div>
        </div>
      </>
    ))}
  </div>

  <div class="sub-label" style="margin-top:40px">Code</div>
  <div class="code-block">
    <pre><span class="c-comment">{"// Transparent (default)"}</span>
<span class="c-tag">{"<AlertCard"}</span> <span class="c-attr">{"type="}</span><span class="c-string">{'"success"'}</span> <span class="c-attr">{"title="}</span><span class="c-string">{'"Ride ended"'}</span> <span class="c-attr">{"body="}</span><span class="c-string">{'"Parked correctly."'}</span> <span class="c-tag">{"/>"}</span>

<span class="c-comment">{"// Solid background"}</span>
<span class="c-tag">{"<AlertCard"}</span> <span class="c-attr">{"type="}</span><span class="c-string">{'"error"'}</span> <span class="c-attr">{"solid"}</span> <span class="c-attr">{"title="}</span><span class="c-string">{'"No signal"'}</span> <span class="c-attr">{"onClose="}</span><span class="c-value">{"() => dismiss()"}</span> <span class="c-tag">{"/>"}</span></pre>
  </div>

  <div class="sub-label" style="margin-top:40px">Toast — the inverted sibling</div>
  <p style="font-size:14px;color:var(--content-body-secondary);line-height:1.6;max-width:560px">
    The <a href="/components/toast" style="color:var(--content-inline-link-enabled);font-weight:600;text-decoration:underline;text-underline-offset:3px">toast</a> is the same component with its light/dark polarity flipped — a dark surface in light mode and a light surface in dark mode — so a transient message reads as elevated against the page.
  </p>

  <div class="sub-label" style="margin-top:40px">Props</div>
  <table class="prop-table">
    <thead>
      <tr><th>Prop</th><th>Type</th><th>Default</th><th>Description</th></tr>
    </thead>
    <tbody>
      <tr><td><code class="token">type</code></td><td><code class="token">'success' | 'info' | 'warning' | 'error' | 'mandatory'</code></td><td>—</td><td>Required. Sets badge, border colour, and ARIA role.</td></tr>
      <tr><td><code class="token">title</code></td><td><code class="token">string</code></td><td>—</td><td>Required. Short label, sentence case.</td></tr>
      <tr><td><code class="token">body</code></td><td><code class="token">string | ReactNode</code></td><td>—</td><td>Required. Explains the situation and/or next step.</td></tr>
      <tr><td><code class="token">solid</code></td><td><code class="token">boolean</code></td><td><code class="token">false</code></td><td>Opaque tinted fill instead of a transparent tint.</td></tr>
      <tr><td><code class="token">onClose</code></td><td><code class="token">() =&gt; void</code></td><td>—</td><td>Renders the dismiss button when provided.</td></tr>
    </tbody>
  </table>

  <div class="sub-label" style="margin-top:40px">Anatomy</div>
  <div class="card card-sm" style="border-radius:16px">
    <div style="display:flex;flex-direction:column;gap:8px;font-size:12px">
      <div style="display:flex;justify-content:space-between"><span style="color:var(--content-body-secondary)">Border radius</span><code class="token">16px</code></div>
      <div style="display:flex;justify-content:space-between"><span style="color:var(--content-body-secondary)">Border</span><code class="token">1.5px solid · status colour</code></div>
      <div style="display:flex;justify-content:space-between"><span style="color:var(--content-body-secondary)">Transparent bg</span><code class="token">8–10% tint of status colour</code></div>
      <div style="display:flex;justify-content:space-between"><span style="color:var(--content-body-secondary)">Solid bg</span><code class="token">opaque tint (color-mix over surface)</code></div>
      <div style="display:flex;justify-content:space-between"><span style="color:var(--content-body-secondary)">Badge</span><code class="token">22px filled · white glyph</code></div>
      <div style="display:flex;justify-content:space-between"><span style="color:var(--content-body-secondary)">Title</span><code class="token">14px / 600 · heading-primary</code></div>
      <div style="display:flex;justify-content:space-between"><span style="color:var(--content-body-secondary)">Body</span><code class="token">13px / 400 · body-secondary</code></div>
    </div>
  </div>
</BaseLayout>

<style>
  .alert-grid {
    display: grid;
    grid-template-columns: 92px 1fr 1fr;
    gap: 14px 18px;
    align-items: center;
  }
  .alert-grid-head {
    font-size: 12px; font-weight: 600;
    color: var(--content-body-secondary);
    text-align: center;
  }
  .alert-grid-label {
    font-size: 13px; font-weight: 600;
    color: var(--content-heading-primary);
  }
  .alert-card-cell { min-width: 0; }
  @media (max-width: 760px) {
    .alert-grid { grid-template-columns: 1fr; gap: 8px; }
    .alert-grid-head:first-child { display: none; }
    .alert-grid-head { text-align: left; margin-top: 16px; }
    .alert-grid-label { margin-top: 16px; }
  }
</style>
