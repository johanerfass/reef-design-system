</style>

<script is:inline>
(function () {
  var badgesOn = false;
  var cardsOn = false;

  var badgeBtn = document.getElementById('pg-btn-badge');
  var cardBtn  = document.getElementById('pg-btn-card');
  if (!badgeBtn || !cardBtn) return;

  badgeBtn.addEventListener('click', function () {
    badgesOn = !badgesOn;
    badgeBtn.textContent = badgesOn ? 'Hide badges' : 'Show badges';
    document.querySelectorAll('.pg-pill').forEach(function (pill, i) {
      setTimeout(function () {
        pill.classList.toggle('badge-active', badgesOn);
      }, i * 80);
    });
  });

  cardBtn.addEventListener('click', function () {
    cardsOn = !cardsOn;
    cardBtn.textContent = cardsOn ? 'Hide cards' : 'Show cards';
    document.querySelectorAll('.pg-card-wrap').forEach(function (card, i) {
      setTimeout(function () {
        card.classList.toggle('card-active', cardsOn);
      }, i * 80);
    });
  });
})();
</script>
