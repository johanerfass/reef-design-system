  .pg-island-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  /* Morphing pill — starts as a circle, expands to pill on .badge-active */
  .pg-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 48px;
    padding: 0 12px;
    border-radius: 999px;
    gap: 0;
    background: var(--fill-frost-medium-enabled);
    backdrop-filter: blur(32px);
    -webkit-backdrop-filter: blur(32px);
    border: 1px solid var(--fill-frost-stroke);
    box-shadow: var(--shadow-shallow);
    color: var(--core-tire);
    cursor: pointer;
    overflow: hidden;
    transition:
      padding 0.4s cubic-bezier(0.34, 1.56, 0.64, 1),
      gap 0.35s ease;
