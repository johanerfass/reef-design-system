  .zone-stack--amber .zone-map-icon { color: rgba(80,50,0,.7); }
  .zone-stack--red   .zone-map-icon { color: rgba(255,255,255,.55); }

  /* ── MULTI-BUTTON STRIP (toolbar) ──────────────────────────────────────── */
