    height: 44px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .zone-signal--speed {
    background: #fff;
    border: 3px solid #e03030;
  }
  .zone-signal--nogo {
    background: #e03030;
  }
  .zone-speed-num {
    font-size: 16px;
    font-weight: 800;
