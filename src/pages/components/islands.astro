    display: flex; align-items: center; justify-content: center;
    border: none; background: transparent; border-radius: 20px;
    cursor: pointer; color: var(--content-body-secondary);
    transition: background .15s, color .15s; flex-shrink: 0;
  }
  .toolbar-btn:hover { background: var(--fill-neutral-soft-enabled); color: var(--content-body-primary); }
  .toolbar-btn:active { background: var(--fill-neutral-medium-enabled); transform: scale(.92); }
  .toolbar-btn--active { background: var(--fill-neutral-soft-enabled); color: var(--content-body-primary); }

  .toolbar-divider { height: 1px; background: var(--fill-neutral-soft-enabled); margin: 2px 4px; flex-shrink: 0; }
  .toolbar-divider-h { width: 1px; background: var(--fill-neutral-soft-enabled); margin: 4px 2px; flex-shrink: 0; }

  /* ── PLAYGROUND ────────────────────────────────────────────────────────── */
  .pg-stage {
