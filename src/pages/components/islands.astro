---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Floating controls">
  <div class="s-overline">02 — Components</div>
  <div class="s-title-row">
    <h1 class="s-title" style="margin-bottom:0">Floating controls</h1>
    <span class="badge badge-ai" title="Not in the Reef Figma library — generated for this showcase"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l1.7 5.3L19 10l-5.3 1.7L12 17l-1.7-5.3L5 10l5.3-1.7z"/></svg>AI generated</span>
  </div>
  <p class="s-desc">A rounded pill that groups icon controls and floats above content. Three forms — bare icon circle, icon + badge pill, multi-button strip — all share the same container shape and sizing. The <strong>material</strong> is the only thing that changes: frosted glass over map or photo, solid white over a neutral UI surface.</p>
  <hr class="s-rule" />

  <div class="ai-notice">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
    <div>
      <div class="ai-notice-title">Showcase extension — not in the Reef Figma library</div>
      <div class="ai-notice-body">"Floating controls" / islands is an R&D exploration (the Archipelago navigation concept), not a shipped Reef component. Showcase-only.</div>
    </div>
  </div>

  <!-- PLATFORM MATERIAL NOTE -->
  <div class="platform-note">
    <div class="platform-note-row">
      <span class="platform-tag">iOS</span>
      <span>Native liquid glass — <code>UIBlurEffect</code> / <code>.glassBackgroundEffect()</code>. The OS material adapts to any content behind it automatically.</span>
    </div>
    <div class="platform-note-row">
      <span class="platform-tag">Android &amp; web</span>
      <span>Reef frosted glass — <code>material-frost-medium</code>. Works on any background; the shadow provides elevation on light surfaces.</span>
    </div>
  </div>

  <!-- BASE STATE -->
  <div class="sub-label" style="margin-top:40px">Base — icon island</div>
  <p style="font-size:13px;color:var(--content-body-secondary);margin-bottom:20px">Frosted circles, 48px, bare icon with no backplate. Each island represents one contextual entry point.</p>
  <div class="map-stage">
    <div class="map-bg" id="isl-map-1"></div>
    <div class="island-row">
      <div style="text-align:center">
        <button class="icon-btn icon-btn-md material-frost-medium" aria-label="Ticket">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-4 0v2"/><line x1="12" y1="12" x2="12" y2="16"/><line x1="10" y1="14" x2="14" y2="14"/></svg>
        </button>
        <div class="island-ann">Ticket</div>
      </div>
      <div style="text-align:center">
        <button class="icon-btn icon-btn-md material-frost-medium" aria-label="Profile">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </button>
        <div class="island-ann">Profile</div>
      </div>
      <div style="text-align:center">
        <button class="icon-btn icon-btn-md material-frost-medium" style="background:rgba(255,255,255,0.85);color:var(--alert-error)" aria-label="Alert">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        </button>
        <div class="island-ann">Alert</div>
      </div>
      <div style="text-align:center">
        <button class="icon-btn icon-btn-md material-frost-medium" aria-label="Group">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </button>
        <div class="island-ann">Group</div>
      </div>
    </div>
  </div>

  <!-- HORIZONTAL PILL — MATERIAL VARIANTS -->
  <div class="sub-label" style="margin-top:40px">Horizontal pill — material variants</div>
  <p style="font-size:13px;color:var(--content-body-secondary);margin-bottom:20px">The pill is always icon-left, badge-right. The background is the only thing that changes based on what it sits on top of.</p>

  <div style="display:flex;gap:16px;flex-wrap:wrap;margin-bottom:8px">

    <!-- Frosted — over map -->
    <div class="material-demo material-demo--map">
      <div class="material-demo-label">Frosted — over map or photo</div>
      <div style="display:flex;flex-direction:column;gap:10px;align-items:flex-start">
        <div class="island-pill island-pill--frosted">
          <div class="island-pill-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-4 0v2"/><line x1="12" y1="12" x2="12" y2="16"/><line x1="10" y1="14" x2="14" y2="14"/></svg>
          </div>
          <span class="badge badge-accent badge-island">Deal!</span>
        </div>
        <div class="island-pill island-pill--frosted">
          <div class="island-pill-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-4 0v2"/><line x1="12" y1="12" x2="12" y2="16"/><line x1="10" y1="14" x2="14" y2="14"/></svg>
          </div>
          <span class="badge badge-brand-hard badge-island">Voi+</span>
        </div>
        <div class="island-pill island-pill--frosted">
          <div class="island-pill-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </div>
          <span class="badge badge-space badge-island">Business</span>
        </div>
        <div class="island-pill island-pill--frosted">
          <div class="island-pill-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-4 0v2"/><line x1="12" y1="12" x2="12" y2="16"/><line x1="10" y1="14" x2="14" y2="14"/></svg>
          </div>
          <span class="badge badge-neutral badge-island">123 min left</span>
        </div>
      </div>
    </div>

    <!-- Solid — over neutral UI -->
    <div class="material-demo material-demo--light">
      <div class="material-demo-label">Solid — over neutral UI surface</div>
      <div style="display:flex;flex-direction:column;gap:10px;align-items:flex-start">
        <div class="island-pill island-pill--solid">
          <div class="island-pill-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-4 0v2"/><line x1="12" y1="12" x2="12" y2="16"/><line x1="10" y1="14" x2="14" y2="14"/></svg>
          </div>
          <span class="badge badge-accent badge-island">Deal!</span>
        </div>
        <div class="island-pill island-pill--solid">
          <div class="island-pill-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-4 0v2"/><line x1="12" y1="12" x2="12" y2="16"/><line x1="10" y1="14" x2="14" y2="14"/></svg>
          </div>
          <span class="badge badge-brand-hard badge-island">Voi+</span>
        </div>
        <div class="island-pill island-pill--solid">
          <div class="island-pill-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </div>
          <span class="badge badge-space badge-island">Business</span>
        </div>
        <div class="island-pill island-pill--solid">
          <div class="island-pill-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-4 0v2"/><line x1="12" y1="12" x2="12" y2="16"/><line x1="10" y1="14" x2="14" y2="14"/></svg>
          </div>
          <span class="badge badge-neutral badge-island">123 min left</span>
        </div>
      </div>
    </div>

  </div>

  <!-- MULTI-BUTTON STRIP -->
  <div class="sub-label" style="margin-top:40px">Multi-button strip</div>
  <p style="font-size:13px;color:var(--content-body-secondary);margin-bottom:20px">Groups two or more icon buttons inside the same pill. Always solid white — frosted doesn't read well with multiple active states. Vertical or horizontal; dividers separate logical groups.</p>

  <div style="display:flex;gap:32px;flex-wrap:wrap;align-items:flex-start;margin-bottom:8px">

    <div style="text-align:center">
      <div class="demo-sub-label">Vertical · small</div>
      <div class="toolbar toolbar--sm">
        <button class="toolbar-btn" aria-label="Layers">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>
        </button>
        <button class="toolbar-btn toolbar-btn--active" aria-label="Map">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"/><line x1="8" y1="2" x2="8" y2="18"/><line x1="16" y1="6" x2="16" y2="22"/></svg>
        </button>
        <div class="toolbar-divider"></div>
        <button class="toolbar-btn" aria-label="Settings">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
        </button>
      </div>
    </div>

    <div style="text-align:center">
      <div class="demo-sub-label">Vertical · medium</div>
      <div class="toolbar toolbar--md">
        <button class="toolbar-btn" aria-label="Zoom in">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
        </button>
        <button class="toolbar-btn" aria-label="Zoom out">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
        </button>
        <div class="toolbar-divider"></div>
        <button class="toolbar-btn" aria-label="My location">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/></svg>
        </button>
      </div>
    </div>

    <div style="text-align:center">
      <div class="demo-sub-label">Horizontal · medium</div>
      <div class="toolbar toolbar--md toolbar--horizontal">
        <button class="toolbar-btn" aria-label="Back">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <button class="toolbar-btn toolbar-btn--active" aria-label="Map">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"/><line x1="8" y1="2" x2="8" y2="18"/><line x1="16" y1="6" x2="16" y2="22"/></svg>
        </button>
        <div class="toolbar-divider-h"></div>
        <button class="toolbar-btn" aria-label="Forward">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>
    </div>

    <div style="text-align:center">
      <div class="demo-sub-label">Vertical · large</div>
      <div class="toolbar toolbar--lg">
        <button class="toolbar-btn" aria-label="History">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 102.13-9.36L1 10"/></svg>
        </button>
        <button class="toolbar-btn" aria-label="Add">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        </button>
      </div>
    </div>

  </div>

  <!-- DROP CARDS -->
  <div class="sub-label" style="margin-top:40px">Drop cards — information from island</div>
  <p style="font-size:13px;color:var(--content-body-secondary);margin-bottom:20px">A card emerges below the island. Two variants: white for service state, dark chestnut for CRM/deal content.</p>
  <div style="display:flex;gap:24px;flex-wrap:wrap">

    <!-- White / service state -->
    <div style="flex:1;min-width:280px">
      <div style="font-size:11px;font-weight:600;letter-spacing:.01em;color:var(--content-body-tertiary);margin-bottom:12px">Service state</div>
      <div class="drop-card-demo">
        <div class="map-stage map-stage--sm">
          <div class="map-bg" id="isl-map-3"></div>
          <div class="drop-card-scene">
            <button class="icon-btn icon-btn-md material-frost-medium" style="background:rgba(255,255,255,0.85);color:var(--alert-error)" aria-label="Alert"></button>
            <div class="drop-caret"></div>
            <div class="drop-card drop-card--white">
              <div class="drop-card-title">Sorry, we're closed</div>
              <div class="drop-card-body">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--core-coral,#F26961)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:2px" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                <span>Due to current weather conditions, local operating hours or other circumstances, vehicles aren't available right now.</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Dark / CRM deal -->
    <div style="flex:1;min-width:280px">
      <div style="font-size:11px;font-weight:600;letter-spacing:.01em;color:var(--content-body-tertiary);margin-bottom:12px">CRM deal</div>
      <div class="drop-card-demo">
        <div class="map-stage map-stage--sm">
          <div class="map-bg" id="isl-map-4"></div>
          <div class="drop-card-scene">
            <button class="icon-btn icon-btn-md material-frost-medium" aria-label="Ticket">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-4 0v2"/><line x1="12" y1="12" x2="12" y2="16"/><line x1="10" y1="14" x2="14" y2="14"/></svg>
            </button>
            <div class="drop-caret drop-caret--dark"></div>
            <div class="drop-card drop-card--dark">
              <div class="drop-card-dark-inner">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="var(--core-coral,#F26961)" aria-hidden="true"><path d="M9 14.25l1.234 1.766a1 1 0 001.546.098L15 12m-2.292-8.33C12.418 3.268 12 4.003 12 4.75v.018a.75.75 0 01-.387.657 4.477 4.477 0 01-2.11.528c-.77 0-1.5-.2-2.113-.528a.75.75 0 01-.388-.66l-.003-.017c0-.745-.418-1.48-1.208-2.081A1.5 1.5 0 004.5 4.75c0 1.61.826 2.848 1.726 3.74a.75.75 0 01.074.998C5.6 10.35 5.25 11.6 5.25 12.75a6.75 6.75 0 1013.5 0c0-1.15-.35-2.4-1.05-3.262a.75.75 0 01.074-.998C18.674 7.598 19.5 6.36 19.5 4.75a1.5 1.5 0 00-1.292-1.483c-.79.6-1.208 1.336-1.208 2.081v.018a.75.75 0 01-.388.659 4.478 4.478 0 01-2.112.528c-.77 0-1.5-.2-2.112-.528a.75.75 0 01-.388-.66z"/></svg>
                <div>
                  <div class="drop-card-dark-title">30 minutes</div>
                  <div class="drop-card-dark-sub">Save unlock fee every time</div>
                </div>
                <div style="margin-left:auto;text-align:right">
                  <div class="drop-card-dark-price-old">39 kr</div>
                  <div class="drop-card-dark-price">29 kr</div>
                </div>
                <div class="drop-card-close">✕</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>

  <!-- ZONE HELPERS -->
  <div class="sub-label" style="margin-top:40px">Zone helpers — vertical stack</div>
  <p style="font-size:13px;color:var(--content-body-secondary);margin-bottom:20px">Complex zone information stacks vertically like physical parking signs. Signal badge on top, map icon below. Color encodes zone type.</p>
  <div class="map-stage">
    <div class="map-bg" id="isl-map-5"></div>
    <div class="zone-group">

      <div style="display:flex;flex-direction:column;align-items:center;gap:12px">
        <div class="zone-stack zone-stack--amber">
          <div class="zone-signal zone-signal--speed">
            <span class="zone-speed-num">10</span>
          </div>
          <div class="zone-map-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"/><line x1="8" y1="2" x2="8" y2="18"/><line x1="16" y1="6" x2="16" y2="22"/></svg>
          </div>
        </div>
        <button class="icon-btn icon-btn-md material-frost-medium" aria-label="Group">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </button>
        <div class="island-ann">Slow zone</div>
      </div>

      <div style="display:flex;flex-direction:column;align-items:center;gap:12px">
        <div class="zone-stack zone-stack--red">
          <div class="zone-signal zone-signal--nogo">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/></svg>
          </div>
