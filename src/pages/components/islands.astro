  .pg-pill-badge {
    max-width: 0;
    overflow: hidden;
    opacity: 0;
    white-space: nowrap;
    flex-shrink: 0;
    transition:
      max-width 0.3s ease 0.15s,
      opacity 0.2s ease 0.2s;
  }
  .pg-pill.badge-active .pg-pill-badge {
    max-width: 120px;
    opacity: 1;
  }

  /* Drop card wrapper — hidden, drops in on .card-active */
  .pg-card-wrap {
