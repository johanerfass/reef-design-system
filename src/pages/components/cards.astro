---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Cards">
  <div class="s-overline">02 — Components</div>
  <h1 class="s-title">Cards</h1>
  <p class="s-desc">The primary raised surface for grouped content. Always white with shadow-card and 32px radius. Never nest cards inside cards — use internal sections with divider lines instead.</p>
  <hr class="s-rule" />

  <div class="sub-label">Standard cards</div>
  <div class="grid-auto">
    <!-- info card -->
    <div class="card">
      <div style="margin-bottom:16px;color:var(--content-icon-primary)">
        <svg width="40" height="40" viewBox="0 0 25 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M15.9 3.958a.75.75 0 0 1 .92.53l3.587 13.39a.75.75 0 0 1-1.449.39l-.745-2.781-1.324 1.996h-.001l-1.828 2.76a2.25 2.25 0 0 1-1.875 1.009h-5.35a.75.75 0 0 1 0-1.5h5.35a.75.75 0 0 0 .625-.336l3.885-5.862-2.325-8.677a.75.75 0 0 1 .53-.92"/><path d="m18.618 11.198.193.724-1.448.388-.602-2.242 1.45-.389zM18.113.614a.75.75 0 0 1 .389 1.45l-2.173.58.683 2.571-1.449.385-.747-2.811a1.25 1.25 0 0 1 .885-1.529zM7.072 20.5a1.75 1.75 0 1 0-3.5 0 1.75 1.75 0 0 0 3.5 0m1.5 0a3.25 3.25 0 1 1-6.5 0 3.25 3.25 0 0 1 6.5 0m13.5 0a1.75 1.75 0 1 0-3.5 0 1.75 1.75 0 0 0 3.5 0m1.5 0a3.25 3.25 0 1 1-6.5 0 3.25 3.25 0 0 1 6.5 0"/></svg>
      </div>
      <div style="font-size:22px;font-weight:600;letter-spacing:-.01em;color:var(--content-heading-primary);margin-bottom:8px">Your nearest scooter</div>
      <div style="font-size:14px;color:var(--content-body-secondary);margin-bottom:24px">3 min walk · Storgatan 14 · Battery 82%</div>
      <button class="btn btn-contrast btn-sm">Reserve now</button>
    </div>

    <!-- stat card -->
    <div class="card">
      <div style="font-size:48px;font-weight:600;letter-spacing:-.03em;color:var(--content-heading-primary);line-height:1;margin-bottom:4px;font-variant-numeric:tabular-nums">€3.90</div>
      <div style="font-size:13px;color:var(--content-body-tertiary);margin-bottom:24px">Today · 2 rides</div>
      <div style="display:flex;flex-direction:column;gap:8px;margin-bottom:24px">
        <div style="display:flex;justify-content:space-between;font-size:13px;color:var(--content-body-secondary)"><span>Unlock fee × 2</span><span>€0.50</span></div>
        <div style="display:flex;justify-content:space-between;font-size:13px;color:var(--content-body-secondary)"><span>13 min + 6 min</span><span>€3.40</span></div>
      </div>
      <button class="btn btn-outlined btn-sm">Full history</button>
    </div>

    <!-- pricing card -->
    <div class="card">
      <div style="font-size:13px;font-weight:600;color:var(--content-body-tertiary);margin-bottom:8px">Pay-as-you-go</div>
      <div class="price-strike">€0.35/min</div>
      <div class="price-current">€0.25<span class="price-unit">/min</span></div>
      <div class="price-save">Save 28% today only</div>
      <div style="margin:20px 0;border-top:1px solid var(--fill-neutral-soft-enabled);padding-top:20px;font-size:13px;color:var(--content-body-secondary)">+ €0.25 unlock fee · Malmö zone</div>
      <button class="btn btn-contrast btn-md" style="width:100%">Start riding</button>
    </div>

    <!-- Voi+ subscription card -->
    <div class="voi-plus-card">
      <div class="voi-plus-badge">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor" stroke="none" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        Voi+
      </div>
      <div class="voi-plus-title">Unlimited rides, one price</div>
      <div class="voi-plus-body">Ride as much as you want for €24.90/month. No unlock fees.</div>
      <div style="display:flex;flex-direction:column;gap:6px;margin-bottom:24px">
        {['Unlimited unlock', 'Priority booking', 'Cancel anytime'].map(item => (
          <div class="voi-plus-item">
            <svg class="voi-plus-check" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            {item}
          </div>
        ))}
      </div>
      <button class="btn btn-md btn-frosted voi-plus-cta">Get Voi+</button>
    </div>
  </div>

  <div class="sub-label" style="margin-top:40px">Ride summary card</div>
  <div class="card" style="max-width:320px">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px">
      <div style="color:var(--content-icon-primary)">
        <svg width="32" height="32" viewBox="0 0 25 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M15.9 3.958a.75.75 0 0 1 .92.53l3.587 13.39a.75.75 0 0 1-1.449.39l-.745-2.781-1.324 1.996h-.001l-1.828 2.76a2.25 2.25 0 0 1-1.875 1.009h-5.35a.75.75 0 0 1 0-1.5h5.35a.75.75 0 0 0 .625-.336l3.885-5.862-2.325-8.677a.75.75 0 0 1 .53-.92"/><path d="m18.618 11.198.193.724-1.448.388-.602-2.242 1.45-.389zM18.113.614a.75.75 0 0 1 .389 1.45l-2.173.58.683 2.571-1.449.385-.747-2.811a1.25 1.25 0 0 1 .885-1.529zM7.072 20.5a1.75 1.75 0 1 0-3.5 0 1.75 1.75 0 0 0 3.5 0m1.5 0a3.25 3.25 0 1 1-6.5 0 3.25 3.25 0 0 1 6.5 0m13.5 0a1.75 1.75 0 1 0-3.5 0 1.75 1.75 0 0 0 3.5 0m1.5 0a3.25 3.25 0 1 1-6.5 0 3.25 3.25 0 0 1 6.5 0"/></svg>
      </div>
      <div class="ride-summary-chip">Saved 28%</div>
    </div>
    <div style="display:flex;gap:24px;margin-bottom:20px">
      <div>
        <div style="font-size:28px;font-weight:600;letter-spacing:-.02em;color:var(--content-heading-primary);line-height:1">13 min</div>
        <div style="font-size:12px;color:var(--content-body-tertiary);margin-top:2px">Duration</div>
      </div>
      <div style="width:1px;background:var(--fill-neutral-soft-enabled)"></div>
      <div>
        <div style="font-size:28px;font-weight:600;letter-spacing:-.02em;color:var(--content-heading-primary);line-height:1">2.4 km</div>
        <div style="font-size:12px;color:var(--content-body-tertiary);margin-top:2px">Distance</div>
      </div>
    </div>
    <div style="border-top:1px solid var(--fill-neutral-soft-enabled);padding-top:16px;display:flex;justify-content:space-between;align-items:center">
      <div>
        <div style="font-size:13px;color:var(--content-body-tertiary);text-decoration:line-through">€4.80</div>
        <div style="font-size:20px;font-weight:600;color:var(--content-heading-primary);letter-spacing:-.01em">€3.45</div>
      </div>
      <button class="btn btn-contrast btn-sm">Rate ride</button>
    </div>
  </div>

  <div class="sub-label" style="margin-top:40px">Reservation banner</div>
  <div class="reservation">
    <div class="reservation-blob" style="width:180px;height:180px;top:-60px;right:40px"></div>
    <div class="reservation-blob" style="width:100px;height:100px;bottom:-20px;right:160px"></div>
    <div style="position:relative;z-index:1">
      <div class="reservation-label">Vehicle reserved</div>
      <div class="reservation-timer" id="res-timer">14:32</div>
      <div class="res-progress"><div class="res-progress-fill" style="width:72%" id="res-progress"></div></div>
    </div>
    <button class="btn btn-sm" style="background:var(--supporting-space);color:#fff;border-radius:32px;font-family:Sora,sans-serif;font-weight:600;cursor:pointer;position:relative;z-index:1;flex-shrink:0">Cancel</button>
  </div>

  <div class="sub-label" style="margin-top:40px">Code</div>
  <div class="code-block">
    <pre><span class="c-comment">{"// Standard card"}</span>
<span class="c-tag">{"<Card"}</span><span class="c-tag">{">"}</span>
  <span class="c-value">{"content"}</span>
<span class="c-tag">{"</Card>"}</span>

<span class="c-comment">{"// Small variant — 24px radius + 24px padding"}</span>
<span class="c-tag">{"<Card"}</span> <span class="c-attr">{"size="}</span><span class="c-string">{'"sm"'}</span><span class="c-tag">{">"}</span>
  <span class="c-value">{"content"}</span>
<span class="c-tag">{"</Card>"}</span>

<span class="c-comment">{"// Voi+ brand card (dark surface exception)"}</span>
<span class="c-tag">{"<VoiPlusCard"}</span>
  <span class="c-attr">{"title="}</span><span class="c-string">{'"Unlimited rides, one price"'}</span>
  <span class="c-attr">{"price="}</span><span class="c-string">{'"€24.90/month"'}</span>
  <span class="c-attr">{"onCta="}</span><span class="c-value">{"handleUpgrade"}</span>
<span class="c-tag">{"/>"}</span></pre>
  </div>

  <div class="sub-label">Card anatomy</div>
  <div class="card card-sm" style="border-radius:16px">
    <div style="display:flex;flex-direction:column;gap:8px;font-size:12px">
      <div style="display:flex;justify-content:space-between"><span style="color:var(--content-body-secondary)">Background</span><code class="token">surface.raised (white)</code></div>
      <div style="display:flex;justify-content:space-between"><span style="color:var(--content-body-secondary)">Border radius</span><code class="token">32px (--radius-xl)</code></div>
      <div style="display:flex;justify-content:space-between"><span style="color:var(--content-body-secondary)">Shadow</span><code class="token">--shadow-card</code></div>
      <div style="display:flex;justify-content:space-between"><span style="color:var(--content-body-secondary)">Padding</span><code class="token">32px (--space-8)</code></div>
      <div style="display:flex;justify-content:space-between"><span style="color:var(--content-body-secondary)">Small variant (card-sm)</span><code class="token">24px radius · 24px padding</code></div>
    </div>
  </div>
</BaseLayout>

<script>
let secs = 14 * 60 + 32;
const total = 15 * 60;
const timerEl = document.getElementById('res-timer');
const progEl = document.getElementById('res-progress');
if (timerEl && progEl) {
  setInterval(() => {
    if (secs <= 0) return;
    secs--;
    const m = String(Math.floor(secs / 60)).padStart(2, '0');
    const s = String(secs % 60).padStart(2, '0');
    timerEl.textContent = `${m}:${s}`;
    (progEl as HTMLElement).style.width = `${(secs / total) * 100}%`;
  }, 1000);
}
</script>
