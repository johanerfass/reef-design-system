---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Switch Card">
  <div class="s-overline">02 — Components</div>
  <h1 class="s-title">Switch card</h1>
  <p class="s-desc">Full-width tab-like selector for two mutually exclusive views or modes. Active state uses Sea fill with white text. Use in place of tabs when the options represent distinct surfaces rather than scrolled sections.</p>
  <hr class="s-rule" />

  <div class="sub-label">Vehicle type selector</div>
  <div class="demo">
    <div style="display:flex;gap:12px;max-width:380px" id="switch-group-1">
      <div class="switch-card switch-card-active" data-switch="1">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="7" cy="17" r="2"/><circle cx="17" cy="17" r="2"/><path d="M5 17H3V7l6-2 4 5h4l2 2-2 1v4"/><path d="M9 5l4 7H9"/></svg>
        <span>Scooter</span>
      </div>
      <div class="switch-card switch-card-inactive" data-switch="1">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="18.5" cy="17.5" r="3.5"/><circle cx="5.5" cy="17.5" r="3.5"/><circle cx="15" cy="5" r="1"/><path d="M12 17.5V14l-3-3 4-3 2 3h2"/></svg>
        <span>E-bike</span>
      </div>
      <div class="switch-card switch-card-inactive" data-switch="1">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
        <span>Fast charge</span>
      </div>
    </div>
  </div>

  <div class="sub-label">Subscription period selector</div>
  <div class="demo">
    <div style="display:flex;gap:12px;max-width:480px" id="switch-group-2">
      <div class="switch-card switch-card-inactive" style="flex:1" data-switch="2">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><line x1="8" y1="14" x2="8.01" y2="14"/></svg>
        <span>Day</span>
      </div>
      <div class="switch-card switch-card-active" style="flex:1" data-switch="2">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        <span>Month</span>
      </div>
      <div class="switch-card switch-card-inactive" style="flex:1" data-switch="2">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><circle cx="8" cy="14" r="0.5" fill="currentColor"/><circle cx="12" cy="14" r="0.5" fill="currentColor"/><circle cx="16" cy="14" r="0.5" fill="currentColor"/></svg>
        <span>Year</span>
      </div>
    </div>
  </div>

  <div class="sub-label">Two-option toggle</div>
  <div class="demo">
    <div style="display:flex;gap:12px;max-width:280px" id="switch-group-3">
      <div class="switch-card switch-card-active" style="flex:1;font-size:14px" data-switch="3">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="3 11 22 2 13 21 11 13 3 11"/></svg>
        <span>Map</span>
      </div>
      <div class="switch-card switch-card-inactive" style="flex:1;font-size:14px" data-switch="3">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
        <span>List</span>
      </div>
    </div>
  </div>

  <div class="sub-label" style="margin-top:40px">Code</div>
  <div class="code-block">
    <pre><span class="c-tag">{"<SwitchCardGroup"}</span>
  <span class="c-attr">{"value="}</span><span class="c-value">{"{selected}"}</span>
  <span class="c-attr">{"onChange="}</span><span class="c-value">{"setSelected"}</span>
<span class="c-tag">{">"}</span>
  <span class="c-tag">{"<SwitchCard"}</span> <span class="c-attr">{"value="}</span><span class="c-string">{'"scooter"'}</span> <span class="c-attr">{"icon="}</span><span class="c-string">{'"<ScooterIcon />"'}</span><span class="c-tag">{">"}</span><span class="c-value">{"Scooter"}</span><span class="c-tag">{"</SwitchCard>"}</span>
  <span class="c-tag">{"<SwitchCard"}</span> <span class="c-attr">{"value="}</span><span class="c-string">{'"ebike"'}</span> <span class="c-attr">{"icon="}</span><span class="c-string">{'"<BikeIcon />"'}</span><span class="c-tag">{">"}</span><span class="c-value">{"E-bike"}</span><span class="c-tag">{"</SwitchCard>"}</span>
<span class="c-tag">{"</SwitchCardGroup>"}</span></pre>
  </div>

  <div class="sub-label">Spec</div>
  <div class="card card-sm" style="border-radius:16px">
    <div style="display:flex;flex-direction:column;gap:8px;font-size:12px">
      <div style="display:flex;justify-content:space-between"><span style="color:var(--content-body-secondary)">Height</span><code class="token">79px</code></div>
      <div style="display:flex;justify-content:space-between"><span style="color:var(--content-body-secondary)">Border radius</span><code class="token">24px</code></div>
      <div style="display:flex;justify-content:space-between"><span style="color:var(--content-body-secondary)">Active fill</span><code class="token">fill.accent.medium (Sea #455F85)</code></div>
      <div style="display:flex;justify-content:space-between"><span style="color:var(--content-body-secondary)">Inactive fill</span><code class="token">surface.overlay (white)</code></div>
      <div style="display:flex;justify-content:space-between"><span style="color:var(--content-body-secondary)">Inactive border</span><code class="token">fill.neutral.medium (Granite)</code></div>
      <div style="display:flex;justify-content:space-between"><span style="color:var(--content-body-secondary)">Font</span><code class="token">12px / 600 · Sora</code></div>
    </div>
  </div>
</BaseLayout>

<script>
document.querySelectorAll('[data-switch]').forEach(card => {
  card.addEventListener('click', (e) => {
    const group = (e.currentTarget as HTMLElement).dataset.switch;
    document.querySelectorAll(`[data-switch="${group}"]`).forEach(c => {
      c.className = c.className.replace('switch-card-active', 'switch-card-inactive');
    });
    const el = e.currentTarget as HTMLElement;
    el.className = el.className.replace('switch-card-inactive', 'switch-card-active');
  });
});
</script>
