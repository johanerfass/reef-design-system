---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Toolbar">
  <div class="s-overline">02 — Components</div>
  <h1 class="s-title">Toolbar</h1>
  <p class="s-desc">Floating strip of icon-button actions that appears contextually above the keyboard or selected content. Groups related actions tightly. Do not use as a replacement for the top navigation bar.</p>
  <hr class="s-rule" />

  <div style="display:flex;align-items:flex-start;gap:12px;background:var(--fill-accent-subtle-enabled);border:1px solid var(--fill-accent-soft-enabled);border-radius:16px;padding:14px 16px;margin-bottom:40px">
    <span class="beta-tag" style="margin-top:1px;flex-shrink:0">New v1.4.0</span>
    <div style="font-size:12px;line-height:1.55;color:var(--content-body-secondary)">The toolbar is rebuilt with liquid and frosted variants, using the new frost material (<code class="token">--fill-frost-medium-enabled</code> with <code class="token">backdrop-filter</code>) for an iOS 26 style glass surface.</div>
  </div>

  <div class="s-overline">Example</div>
  <div style="display:flex;gap:32px;flex-wrap:wrap;align-items:flex-start">

    <!-- Small vertical -->
    <div>
      <div style="font-size:11px;font-weight:600;letter-spacing:.04em;color:var(--content-body-tertiary);margin-bottom:12px">Small (4px padding)</div>
      <div class="toolbar toolbar--sm">
        <button class="toolbar-btn" aria-label="Layers">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>
        </button>
        <button class="toolbar-btn toolbar-btn--active" aria-label="Map">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"/><line x1="8" y1="2" x2="8" y2="18"/><line x1="16" y1="6" x2="16" y2="22"/></svg>
        </button>
        <div class="toolbar-divider"></div>
        <button class="toolbar-btn" aria-label="Settings">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
        </button>
      </div>
    </div>

    <!-- Medium vertical -->
    <div>
      <div style="font-size:11px;font-weight:600;letter-spacing:.04em;color:var(--content-body-tertiary);margin-bottom:12px">Medium (8px padding)</div>
      <div class="toolbar toolbar--md">
        <button class="toolbar-btn" aria-label="Zoom in">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
        </button>
        <button class="toolbar-btn" aria-label="Zoom out">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
        </button>
        <div class="toolbar-divider"></div>
        <button class="toolbar-btn" aria-label="Location">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/></svg>
        </button>
      </div>
    </div>

    <!-- Large vertical -->
    <div>
      <div style="font-size:11px;font-weight:600;letter-spacing:.04em;color:var(--content-body-tertiary);margin-bottom:12px">Large (12px padding)</div>
      <div class="toolbar toolbar--lg">
        <button class="toolbar-btn" aria-label="Ride history">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 102.13-9.36L1 10"/></svg>
        </button>
        <button class="toolbar-btn" aria-label="Add">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        </button>
      </div>
    </div>

    <!-- Horizontal medium -->
    <div>
      <div style="font-size:11px;font-weight:600;letter-spacing:.04em;color:var(--content-body-tertiary);margin-bottom:12px">Horizontal (medium)</div>
      <div class="toolbar toolbar--md toolbar--horizontal">
        <button class="toolbar-btn" aria-label="Back">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <button class="toolbar-btn toolbar-btn--active" aria-label="Map">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"/><line x1="8" y1="2" x2="8" y2="18"/><line x1="16" y1="6" x2="16" y2="22"/></svg>
        </button>
        <div class="toolbar-divider-h"></div>
        <button class="toolbar-btn" aria-label="Forward">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>
    </div>

  </div>

  <div class="s-overline" style="margin-top:40px">Code</div>
  <div class="code-block"><pre><span class="c-comment">/* Small vertical (default) */</span>
<span class="c-tag">&lt;div</span> <span class="c-attr">class</span>=<span class="c-str">"toolbar toolbar--sm"</span><span class="c-tag">&gt;</span>
  <span class="c-tag">&lt;button</span> <span class="c-attr">class</span>=<span class="c-str">"toolbar-btn"</span><span class="c-tag">&gt;</span>...<span class="c-tag">&lt;/button&gt;</span>
  <span class="c-tag">&lt;button</span> <span class="c-attr">class</span>=<span class="c-str">"toolbar-btn toolbar-btn--active"</span><span class="c-tag">&gt;</span>...<span class="c-tag">&lt;/button&gt;</span>
  <span class="c-tag">&lt;div</span> <span class="c-attr">class</span>=<span class="c-str">"toolbar-divider"</span><span class="c-tag">&gt;&lt;/div&gt;</span>
  <span class="c-tag">&lt;button</span> <span class="c-attr">class</span>=<span class="c-str">"toolbar-btn"</span><span class="c-tag">&gt;</span>...<span class="c-tag">&lt;/button&gt;</span>
<span class="c-tag">&lt;/div&gt;</span>

<span class="c-comment">/* Horizontal variant */</span>
<span class="c-tag">&lt;div</span> <span class="c-attr">class</span>=<span class="c-str">"toolbar toolbar--md toolbar--horizontal"</span><span class="c-tag">&gt;</span>...<span class="c-tag">&lt;/div&gt;</span></pre></div>

  <div class="s-overline" style="margin-top:40px">Anatomy</div>
  <table class="prop-table">
    <thead><tr><th>Token</th><th>Value</th><th>Note</th></tr></thead>
    <tbody>
      <tr><td><code>Background</code></td><td><code>white</code></td><td>Always white — no transparency</td></tr>
      <tr><td><code>Border</code></td><td><code>1px solid #e8e4e5</code></td><td>Subtle edge border on container</td></tr>
      <tr><td><code>Icon button</code></td><td><code>40×40px, 20px radius</code></td><td>Small icon button — all sizes</td></tr>
      <tr><td><code>Small padding</code></td><td><code>4px</code></td><td>Gap 4px, container radius 32px</td></tr>
      <tr><td><code>Medium padding</code></td><td><code>8px</code></td><td>Gap 8px, container radius 32px</td></tr>
      <tr><td><code>Large padding</code></td><td><code>12px</code></td><td>Gap 12px, container radius 48px</td></tr>
      <tr><td><code>Active state</code></td><td><code>--fill-neutral-soft-enabled bg</code></td><td>Subtle fill, same size</td></tr>
      <tr><td><code>Divider (vertical)</code></td><td><code>1px horizontal line</code></td><td>Separates action groups</td></tr>
    </tbody>
  </table>
</BaseLayout>

<style>
  .toolbar {
    display: inline-flex;
    flex-direction: column;
    background: var(--surface-raised-enabled);
    border: 1px solid var(--fill-neutral-soft-enabled);
    border-radius: 32px;
    gap: 4px;
  }
  .toolbar--sm { padding: 4px; gap: 4px; border-radius: 32px; }
  .toolbar--md { padding: 8px; gap: 8px; border-radius: 32px; }
  .toolbar--lg { padding: 12px; gap: 12px; border-radius: 48px; }
  .toolbar--horizontal { flex-direction: row; }

  .toolbar-btn {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    background: transparent;
    border-radius: 20px;
    cursor: pointer;
    color: var(--content-body-secondary);
    transition: background .15s, color .15s;
    flex-shrink: 0;
  }
  .toolbar-btn:hover {
    background: var(--fill-neutral-soft-enabled);
    color: var(--content-body-primary);
  }
  .toolbar-btn:active {
    background: var(--fill-neutral-medium-enabled);
    transform: scale(.92);
  }
  .toolbar-btn--active {
    background: var(--fill-neutral-soft-enabled);
    color: var(--content-body-primary);
  }

  .toolbar-divider {
    height: 1px;
    background: var(--fill-neutral-soft-enabled);
    margin: 2px 4px;
    flex-shrink: 0;
  }
  .toolbar-divider-h {
    width: 1px;
    background: var(--fill-neutral-soft-enabled);
    margin: 4px 2px;
    flex-shrink: 0;
  }
</style>
