---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Banner">
  <div class="s-overline">02 — Components</div>
  <h1 class="s-title">Banner</h1>
  <p class="s-desc">Persistent full-width notification for system-level messages. Use sparingly — one at a time, never stacked. Dismiss via the close action only; never auto-dismiss a banner.</p>
  <hr class="s-rule" />

  <div class="s-overline">Mobile</div>
  <div class="banner-frame">
    <div class="banner">
      <!-- Coral inbox icon -->
      <svg class="banner-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--core-coral)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/>
        <path d="M5.45 5.11L2 12v6a2 2 0 002 2h16a2 2 0 002-2v-6l-3.45-6.89A2 2 0 0016.76 4H7.24a2 2 0 00-1.79 1.11z"/>
      </svg>
      <div class="banner-body">
        <div class="banner-title">Helmet required in this area</div>
        <div class="banner-desc">Local regulations require you to wear a helmet while riding in Stockholm.</div>
      </div>
      <button class="banner-btn">Learn more</button>
    </div>
  </div>

  <div class="s-overline" style="margin-top:40px">Web — integrated</div>
  <p style="font-size:14px;color:var(--content-body-secondary);line-height:1.6;max-width:560px;margin-bottom:20px">
    On web the banner becomes a contained, rounded surface that sits inline in the page flow and stretches to its container. Severity is carried by a coloured leading icon and a thin accent edge, while the surface stays white so it reads calmly against the page. Inline controls hover and press against <code class="token">surface.raised.hover</code> / <code class="token">pressed</code> — the lightest neutral steps, never the darker fills.
  </p>
  <div class="banner-web-stack">
    <div class="banner-web banner-web--info">
      <span class="banner-web-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="11" x2="12" y2="16"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg></span>
      <div class="banner-web-body">
        <div class="banner-web-title">Scheduled maintenance tonight</div>
        <div class="banner-web-desc">The app may be briefly unavailable between 2–3am CET while we ship improvements.</div>
      </div>
      <div class="banner-web-actions">
        <button class="banner-web-btn">Learn more</button>
        <button class="banner-web-close" aria-label="Dismiss"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
      </div>
    </div>

    <div class="banner-web banner-web--success">
      <span class="banner-web-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg></span>
      <div class="banner-web-body">
        <div class="banner-web-title">Your account is verified</div>
        <div class="banner-web-desc">You can now unlock vehicles and start a ride straight from the map.</div>
      </div>
      <div class="banner-web-actions">
        <button class="banner-web-close" aria-label="Dismiss"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
      </div>
    </div>

    <div class="banner-web banner-web--warning">
      <span class="banner-web-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg></span>
      <div class="banner-web-body">
        <div class="banner-web-title">Low battery in your area</div>
        <div class="banner-web-desc">Some vehicles nearby are running low. Check the range before you start a longer trip.</div>
      </div>
      <div class="banner-web-actions">
        <button class="banner-web-btn">View map</button>
        <button class="banner-web-close" aria-label="Dismiss"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
      </div>
    </div>

    <div class="banner-web banner-web--error">
      <span class="banner-web-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg></span>
      <div class="banner-web-body">
        <div class="banner-web-title">Payment failed</div>
        <div class="banner-web-desc">We couldn't charge your card. Update your payment method to keep riding.</div>
      </div>
      <div class="banner-web-actions">
        <button class="banner-web-btn">Update</button>
        <button class="banner-web-close" aria-label="Dismiss"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
      </div>
    </div>

    <div class="banner-web banner-web--brand">
      <span class="banner-web-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11l18-5v12L3 14v-3z"/><path d="M11.6 16.8a3 3 0 1 1-5.8-1.6"/></svg></span>
      <div class="banner-web-body">
        <div class="banner-web-title">Voi+ is here</div>
        <div class="banner-web-desc">Unlock free rides and member pricing across every city you ride in.</div>
      </div>
      <div class="banner-web-actions">
        <button class="banner-web-btn">See benefits</button>
        <button class="banner-web-close" aria-label="Dismiss"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
      </div>
    </div>
  </div>

  <div class="s-overline" style="margin-top:40px">Usage</div>
  <p style="font-size:14px;color:var(--content-body-secondary);line-height:1.6;max-width:560px">
    Use the banner for persistent, non-dismissible contextual information that applies to the current screen state — for example, a local regulation, a service interruption, or a required action. Because it takes significant vertical space and cannot be dismissed, use it only for information the user must be aware of.
  </p>

  <div class="s-overline" style="margin-top:40px">Code</div>
  <div class="code-block"><pre><span class="c-tag">&lt;div</span> <span class="c-attr">class</span>=<span class="c-str">"banner"</span><span class="c-tag">&gt;</span>
  <span class="c-comment">&lt;!-- 24×24 coral icon --&gt;</span>
  <span class="c-tag">&lt;svg</span> <span class="c-attr">class</span>=<span class="c-str">"banner-icon"</span> <span class="c-attr">width</span>=<span class="c-str">"24"</span> <span class="c-attr">height</span>=<span class="c-str">"24"</span><span class="c-tag">&gt;</span>...<span class="c-tag">&lt;/svg&gt;</span>
  <span class="c-tag">&lt;div</span> <span class="c-attr">class</span>=<span class="c-str">"banner-body"</span><span class="c-tag">&gt;</span>
    <span class="c-tag">&lt;div</span> <span class="c-attr">class</span>=<span class="c-str">"banner-title"</span><span class="c-tag">&gt;</span>Title<span class="c-tag">&lt;/div&gt;</span>
    <span class="c-tag">&lt;div</span> <span class="c-attr">class</span>=<span class="c-str">"banner-desc"</span><span class="c-tag">&gt;</span>Supporting body text<span class="c-tag">&lt;/div&gt;</span>
  <span class="c-tag">&lt;/div&gt;</span>
  <span class="c-comment">&lt;!-- optional small CTA button --&gt;</span>
  <span class="c-tag">&lt;button</span> <span class="c-attr">class</span>=<span class="c-str">"banner-btn"</span><span class="c-tag">&gt;</span>Action<span class="c-tag">&lt;/button&gt;</span>
<span class="c-tag">&lt;/div&gt;</span></pre></div>

  <div class="s-overline" style="margin-top:40px">Anatomy</div>
  <table class="prop-table">
    <thead><tr><th>Token</th><th>Value</th><th>Note</th></tr></thead>
    <tbody>
      <tr><td><code>Width</code></td><td><code>375px (full width)</code></td><td>Spans full container — no max-width</td></tr>
      <tr><td><code>Border radius</code></td><td><code>0</code></td><td>Flat bar — no rounded corners</td></tr>
      <tr><td><code>Shadow</code></td><td><code>none</code></td><td>Flat, not elevated</td></tr>
      <tr><td><code>Background</code></td><td><code>white</code></td><td>Always white surface</td></tr>
      <tr><td><code>Padding</code></td><td><code>16px right / bottom / left</code></td><td>No special top — omit the 48px status-bar offset in reference</td></tr>
      <tr><td><code>Layout</code></td><td><code>flex, row, gap 8px, align flex-start</code></td><td>Icon | content | button</td></tr>
      <tr><td><code>Icon</code></td><td><code>24×24px, coral #F26961</code></td><td>Flex-shrink 0, aligned to top</td></tr>
      <tr><td><code>Title</code></td><td><code>16px / 600 / #282425</code></td><td>Bold, sentence case</td></tr>
      <tr><td><code>Body</code></td><td><code>14px / 400 / #282425</code></td><td>Regular weight</td></tr>
      <tr><td><code>CTA button</code></td><td><code>40px height, 32px radius, #e8e4e5 bg</code></td><td>Small neutral soft button — tire text</td></tr>
    </tbody>
  </table>
</BaseLayout>

<style>
  .banner-frame {
    max-width: 375px;
    overflow: hidden;
  }
  .banner {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 8px;
    padding: 16px;
    background: var(--surface-raised-enabled);
    border-radius: 0;
  }
  .banner-icon {
    flex-shrink: 0;
    margin-top: 2px;
  }
  .banner-body {
    flex: 1;
    min-width: 0;
  }
  .banner-title {
    font-size: 16px;
    font-weight: 600;
    color: var(--content-heading-primary);
    margin-bottom: 2px;
  }
  .banner-desc {
    font-size: 14px;
    font-weight: 400;
    color: var(--content-body-secondary);
    line-height: 1.5;
  }
  .banner-btn {
    flex-shrink: 0;
    height: 40px;
    padding: 0 16px;
    background: var(--fill-neutral-soft-enabled);
    color: var(--content-body-primary);
    border: none;
    border-radius: 32px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    font-family: inherit;
    align-self: center;
    white-space: nowrap;
    transition: background .15s, transform .1s;
  }
  .banner-btn:hover { background: var(--fill-neutral-soft-hover); }
  .banner-btn:active { background: var(--fill-neutral-soft-pressed); transform: scale(.97); }

  /* ─── Web banner — integrated, responsive ─────────────────────────────── */
  .banner-web-stack {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 720px;
  }
  .banner-web {
    --banner-accent: var(--alert-info);
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 16px 16px 16px 18px;
    background: var(--surface-raised-enabled);
    border: 1px solid var(--fill-neutral-soft-enabled);
    border-left: 4px solid var(--banner-accent);
    border-radius: 16px;
    box-shadow: var(--shadow-xs);
  }
  .banner-web--info    { --banner-accent: var(--alert-info); }
  .banner-web--success { --banner-accent: var(--alert-success); }
  .banner-web--warning { --banner-accent: var(--alert-warning); }
  .banner-web--error   { --banner-accent: var(--alert-error); }
  .banner-web--brand   { --banner-accent: var(--core-coral); }
  .banner-web-icon {
    flex-shrink: 0;
    color: var(--banner-accent);
    margin-top: 1px;
    display: flex;
  }
  .banner-web-body { flex: 1; min-width: 0; }
  .banner-web-title {
    font-size: 15px;
    font-weight: 600;
    color: var(--content-heading-primary);
    margin-bottom: 2px;
  }
  .banner-web-desc {
    font-size: 13px;
    color: var(--content-body-secondary);
    line-height: 1.5;
  }
  .banner-web-actions {
    display: flex;
    align-items: center;
    gap: 4px;
    flex-shrink: 0;
  }
  .banner-web-btn {
    height: 36px;
    padding: 0 14px;
    border: none;
    border-radius: 18px;
    background: transparent;
    color: var(--content-body-primary);
    font-family: inherit;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
    transition: background .15s;
  }
  .banner-web-btn:hover  { background: var(--surface-raised-hover); }
  .banner-web-btn:active { background: var(--surface-raised-pressed); }
  .banner-web-close {
    width: 32px;
    height: 32px;
    flex-shrink: 0;
    border: none;
    border-radius: 50%;
    background: transparent;
    color: var(--content-body-tertiary);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background .15s, color .15s;
  }
  .banner-web-close:hover  { background: var(--surface-raised-hover); color: var(--content-body-primary); }
  .banner-web-close:active { background: var(--surface-raised-pressed); }
  @media (max-width: 600px) {
    .banner-web { flex-wrap: wrap; }
    .banner-web-actions { width: 100%; justify-content: flex-end; }
  }
</style>
