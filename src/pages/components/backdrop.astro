---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Backdrop">
  <div class="s-overline">02 — Components</div>
  <h1 class="s-title">Backdrop</h1>
  <p class="s-desc">Full-screen scrim behind modals and bottom sheets. Dims content without fully obscuring it. Tapping the backdrop always closes the overlay — implement this dismiss behaviour without exception.</p>
  <hr class="s-rule" />

  <div class="s-overline">Example</div>
  <div class="demo-frame">
    <div class="mock-screen">
      <div class="mock-card">
        <div class="mock-line" style="width:60%"></div>
        <div class="mock-line" style="width:80%;opacity:.5"></div>
        <div class="mock-line" style="width:45%;opacity:.5"></div>
      </div>
      <div class="mock-card">
        <div class="mock-line" style="width:50%"></div>
        <div class="mock-line" style="width:70%;opacity:.5"></div>
      </div>
    </div>
    <div class="backdrop-demo"></div>
    <div class="mock-sheet">
      <div class="sheet-handle"></div>
      <div class="mock-line" style="width:55%"></div>
      <div class="mock-line" style="width:75%;opacity:.5;margin-top:8px"></div>
    </div>
  </div>

  <div class="s-overline" style="margin-top:40px">Code</div>
  <div class="code-block"><pre><span class="c-comment">/* Backdrop sits directly behind overlays — fixed, full-screen */</span>
<span class="c-tag">&lt;div</span> <span class="c-attr">class</span>=<span class="c-str">"backdrop"</span><span class="c-tag">&gt;&lt;/div&gt;</span></pre></div>

  <div class="s-overline" style="margin-top:40px">Anatomy</div>
  <table class="prop-table">
    <thead><tr><th>Token</th><th>Value</th><th>Note</th></tr></thead>
    <tbody>
      <tr><td><code>Background</code></td><td><code>rgba(0,0,0,0.40)</code></td><td>Fixed opacity — do not increase</td></tr>
      <tr><td><code>Position</code></td><td><code>fixed; inset:0</code></td><td>Always covers the full viewport</td></tr>
      <tr><td><code>z-index</code></td><td><code>below the overlay, above content</code></td><td>Dialog/sheet sits on top</td></tr>
    </tbody>
  </table>
</BaseLayout>

<style>
  .demo-frame {
    position: relative;
    border-radius: 24px;
    overflow: hidden;
    height: 320px;
    background: var(--surface-base-enabled);
    box-shadow: var(--shadow-card);
  }
  .mock-screen {
    position: absolute;
    inset: 0;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .mock-card {
    background: var(--surface-raised-enabled);
    border-radius: 16px;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .mock-line {
    height: 10px;
    background: var(--fill-neutral-medium-enabled);
    border-radius: 5px;
  }
  .backdrop-demo {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.40);
  }
  .mock-sheet {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: var(--surface-raised-enabled);
    border-radius: 24px 24px 0 0;
    padding: 12px 24px 28px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
  .sheet-handle {
    width: 36px;
    height: 4px;
    border-radius: 2px;
    background: var(--fill-neutral-medium-enabled);
    align-self: center;
    margin-bottom: 20px;
  }
</style>
