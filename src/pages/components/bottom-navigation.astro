---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Bottom navigation">
  <div class="s-overline">02 — Components</div>
  <h1 class="s-title">Bottom navigation</h1>
  <p class="s-desc">Primary app-level navigation anchored to the bottom edge. 3–5 destinations maximum. Active tab uses a filled icon; inactive tabs use outlined icons. Always includes safe-area inset padding for iOS.</p>
  <hr class="s-rule" />

  <div class="sub-label">iOS Tab Bar style — 80px, icon + label</div>
  <div class="demo" style="max-width:375px;padding:0;overflow:hidden;border-radius:16px">
    <div class="bottom-nav" id="ios-nav">
      <button class="bottom-nav-item active" data-nav="ios">
        <div class="bottom-nav-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        </div>
        <span class="bottom-nav-label">Home</span>
      </button>
      <button class="bottom-nav-item" data-nav="ios">
        <div class="bottom-nav-icon">
          <div class="bottom-nav-badge">3</div>
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"/><line x1="8" y1="2" x2="8" y2="18"/><line x1="16" y1="6" x2="16" y2="22"/></svg>
        </div>
        <span class="bottom-nav-label">Rides</span>
      </button>
      <button class="bottom-nav-item" data-nav="ios">
        <div class="bottom-nav-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
        </div>
        <span class="bottom-nav-label">Wallet</span>
      </button>
      <button class="bottom-nav-item" data-nav="ios">
        <div class="bottom-nav-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </div>
        <span class="bottom-nav-label">Profile</span>
      </button>
    </div>
  </div>

  <div class="sub-label">Material Navigation Bar — pill indicator</div>
  <div class="demo" style="max-width:375px;padding:0;overflow:hidden;border-radius:16px">
    <div class="bottom-nav bottom-nav--material" id="mat-nav">
      <button class="bottom-nav-item active" data-nav="mat">
        <div class="bottom-nav-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
        </div>
        <span class="bottom-nav-label">Home</span>
      </button>
      <button class="bottom-nav-item" data-nav="mat">
        <div class="bottom-nav-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        </div>
        <span class="bottom-nav-label">Search</span>
      </button>
      <button class="bottom-nav-item" data-nav="mat">
        <div class="bottom-nav-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
        </div>
        <span class="bottom-nav-label">Alerts</span>
      </button>
      <button class="bottom-nav-item" data-nav="mat">
        <div class="bottom-nav-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
        </div>
        <span class="bottom-nav-label">You</span>
      </button>
    </div>
  </div>

  <div class="sub-label" style="margin-top:40px">Code</div>
  <div class="code-block"><pre><span class="c-comment">/* iOS style */</span>
<span class="c-tag">&lt;nav</span> <span class="c-attr">class</span>=<span class="c-str">"bottom-nav"</span><span class="c-tag">&gt;</span>
  <span class="c-tag">&lt;button</span> <span class="c-attr">class</span>=<span class="c-str">"bottom-nav-item active"</span><span class="c-tag">&gt;</span>
    <span class="c-tag">&lt;div</span> <span class="c-attr">class</span>=<span class="c-str">"bottom-nav-icon"</span><span class="c-tag">&gt;</span><span class="c-comment">&lt;!-- badge optional --&gt;</span><span class="c-tag">&lt;/div&gt;</span>
    <span class="c-tag">&lt;span</span> <span class="c-attr">class</span>=<span class="c-str">"bottom-nav-label"</span><span class="c-tag">&gt;</span>Home<span class="c-tag">&lt;/span&gt;</span>
  <span class="c-tag">&lt;/button&gt;</span>
<span class="c-tag">&lt;/nav&gt;</span>

<span class="c-comment">/* Material style — adds pill indicator on active */</span>
<span class="c-tag">&lt;nav</span> <span class="c-attr">class</span>=<span class="c-str">"bottom-nav bottom-nav--material"</span><span class="c-tag">&gt;</span>...<span class="c-tag">&lt;/nav&gt;</span>

<span class="c-comment">/* Notification badge */</span>
<span class="c-tag">&lt;div</span> <span class="c-attr">class</span>=<span class="c-str">"bottom-nav-icon"</span><span class="c-tag">&gt;</span>
  <span class="c-tag">&lt;div</span> <span class="c-attr">class</span>=<span class="c-str">"bottom-nav-badge"</span><span class="c-tag">&gt;</span>3<span class="c-tag">&lt;/div&gt;</span>
  <span class="c-comment">&lt;!-- svg icon --&gt;</span>
<span class="c-tag">&lt;/div&gt;</span></pre></div>

  <div class="sub-label" style="margin-top:40px">Anatomy</div>
  <table class="prop-table">
    <thead><tr><th>Token</th><th>Value</th><th>Note</th></tr></thead>
    <tbody>
      <tr><td><code>Height</code></td><td><code>80px</code></td><td>Includes 16px bottom padding for safe-area proxy</td></tr>
      <tr><td><code>Background</code></td><td><code>--surface-raised-enabled</code></td><td>White — contrast with page background</td></tr>
      <tr><td><code>Border</code></td><td><code>1px top, neutral-soft</code></td><td>Subtle separator from content</td></tr>
      <tr><td><code>Icon size</code></td><td><code>24×24px</code></td><td>Consistent with all icon buttons</td></tr>
      <tr><td><code>Label</code></td><td><code>10px / 600</code></td><td>Small, semibold. Always shown in iOS style</td></tr>
      <tr><td><code>Badge</code></td><td><code>16px min-width, error red</code></td><td>Top-right of icon. 9px font, 700 weight</td></tr>
      <tr><td><code>Material pill</code></td><td><code>neutral-soft bg, 16px radius, inset -6px ±24px</code></td><td>Pseudo-element behind active icon</td></tr>
      <tr><td><code>Max items</code></td><td><code>5</code></td><td>HIG & Material both cap at 5 destinations</td></tr>
    </tbody>
  </table>
</BaseLayout>

<script>
  ['ios','mat'].forEach(group => {
    document.querySelectorAll(`[data-nav="${group}"]`).forEach(btn => {
      btn.addEventListener('click', (e) => {
        document.querySelectorAll(`[data-nav="${group}"]`).forEach(b => b.classList.remove('active'));
        (e.currentTarget as HTMLElement).classList.add('active');
      });
    });
  });
</script>
