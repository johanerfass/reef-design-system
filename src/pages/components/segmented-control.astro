---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Segmented control">
  <div class="s-overline">02 — Components</div>
  <div class="s-title-row">
    <h1 class="s-title" style="margin-bottom:0">Segmented control</h1>
    <span class="badge badge-ai" title="Not in the Reef Figma library — generated for this showcase"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l1.7 5.3L19 10l-5.3 1.7L12 17l-1.7-5.3L5 10l5.3-1.7z"/></svg>AI generated</span>
  </div>
  <p class="s-desc">Inline toggle for 2–4 mutually exclusive views or filter states. Used for switching between related views (map/list), sort orders, or content tabs. Do not exceed 4 segments — use a select or chips for more options.</p>
  <hr class="s-rule" />

  <div class="ai-notice">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
    <div>
      <div class="ai-notice-title">Showcase extension — not in the Reef Figma library</div>
      <div class="ai-notice-body">Reef switches between options with <code>button-toggle</code> or <code>chip-filter</code> — there is no dedicated segmented-control component in the library.</div>
    </div>
  </div>

  <div class="sub-label">Default (medium)</div>
  <div class="demo">
    <div class="segmented" id="seg-view" role="group" aria-label="View mode">
      <button class="segmented-btn active" data-seg="view">Map</button>
      <button class="segmented-btn" data-seg="view">List</button>
      <button class="segmented-btn" data-seg="view">Saved</button>
    </div>
  </div>

  <div class="sub-label">Large</div>
  <div class="demo">
    <div class="segmented segmented--lg" id="seg-mode" role="group" aria-label="Ride mode">
      <button class="segmented-btn active" data-seg="mode">Standard</button>
      <button class="segmented-btn" data-seg="mode">Eco</button>
      <button class="segmented-btn" data-seg="mode">Sport</button>
    </div>
  </div>

  <div class="sub-label">Two options</div>
  <div class="demo">
    <div class="segmented" id="seg-period" role="group" aria-label="Period">
      <button class="segmented-btn active" data-seg="period">Week</button>
      <button class="segmented-btn" data-seg="period">Month</button>
    </div>
  </div>

  <div class="sub-label">Disabled</div>
  <div class="demo">
    <div class="segmented" style="opacity:.4;pointer-events:none" role="group" aria-label="Disabled example">
      <button class="segmented-btn active">Option A</button>
      <button class="segmented-btn">Option B</button>
      <button class="segmented-btn">Option C</button>
    </div>
  </div>

  <div class="sub-label" style="margin-top:40px">Code</div>
  <div class="code-block"><pre><span class="c-comment">/* Default */</span>
<span class="c-tag">&lt;div</span> <span class="c-attr">class</span>=<span class="c-str">"segmented"</span> <span class="c-attr">role</span>=<span class="c-str">"group"</span> <span class="c-attr">aria-label</span>=<span class="c-str">"View mode"</span><span class="c-tag">&gt;</span>
  <span class="c-tag">&lt;button</span> <span class="c-attr">class</span>=<span class="c-str">"segmented-btn active"</span><span class="c-tag">&gt;</span>Map<span class="c-tag">&lt;/button&gt;</span>
  <span class="c-tag">&lt;button</span> <span class="c-attr">class</span>=<span class="c-str">"segmented-btn"</span><span class="c-tag">&gt;</span>List<span class="c-tag">&lt;/button&gt;</span>
<span class="c-tag">&lt;/div&gt;</span>

<span class="c-comment">/* Large */</span>
<span class="c-tag">&lt;div</span> <span class="c-attr">class</span>=<span class="c-str">"segmented segmented--lg"</span><span class="c-tag">&gt;</span>...<span class="c-tag">&lt;/div&gt;</span></pre></div>

  <div class="sub-label" style="margin-top:40px">Anatomy</div>
  <table class="prop-table">
    <thead><tr><th>Token</th><th>Value</th><th>Note</th></tr></thead>
    <tbody>
      <tr><td><code>Container</code></td><td><code>neutral-soft bg, 12px radius, 3px padding</code></td><td>The pill tray</td></tr>
      <tr><td><code>Button height</code></td><td><code>36px (md), 44px (lg)</code></td><td>lg meets HIG 44px touch minimum</td></tr>
      <tr><td><code>Active state</code></td><td><code>white bg, 9px radius, shadow</code></td><td>Floating panel on top of tray</td></tr>
      <tr><td><code>Active font</code></td><td><code>600 (SemiBold)</code></td><td>Regular weight when inactive</td></tr>
      <tr><td><code>Max items</code></td><td><code>5</code></td><td>HIG recommends 2–5 segments</td></tr>
      <tr><td><code>Colour</code></td><td><code>Tire active — never Coral</code></td><td>Coral is brand only</td></tr>
    </tbody>
  </table>

  <div class="sub-label" style="margin-top:40px">Platform notes</div>
  <div class="grid-2" style="gap:12px">
    <div class="card card-sm" style="border-radius:16px">
      <p style="font-size:11px;font-weight:700;color:var(--content-body-tertiary);margin-bottom:6px">iOS (HIG)</p>
      <p style="font-size:13px;color:var(--content-body-secondary);line-height:1.5">Maps to <code class="token">UISegmentedControl</code>. Use <code class="token">selectedSegmentTintColor</code> for active pill. Support <code class="token">UIAccessibility</code> via <code class="token">accessibilityLabel</code> per segment.</p>
    </div>
    <div class="card card-sm" style="border-radius:16px">
      <p style="font-size:11px;font-weight:700;color:var(--content-body-tertiary);margin-bottom:6px">Android (Material)</p>
      <p style="font-size:13px;color:var(--content-body-secondary);line-height:1.5">Use Material <code class="token">ButtonGroup</code> (filled) or <code class="token">SingleChoiceSegmentedButtonRow</code> (M3). Map Tire to active container colour.</p>
    </div>
  </div>
</BaseLayout>

<script>
  document.querySelectorAll('[data-seg]').forEach(btn => {
    btn.addEventListener('click', (e) => {
      const b = e.currentTarget as HTMLElement;
      const group = b.dataset.seg!;
      document.querySelectorAll(`[data-seg="${group}"]`).forEach(s => s.classList.remove('active'));
      b.classList.add('active');
    });
  });
</script>
