---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="FAB">
  <div class="s-overline">02 — Components</div>
  <h1 class="s-title">Floating action button</h1>
  <p class="s-desc">A single high-priority action floating above all other content. One FAB per screen maximum. Use only when the action is the dominant task for that screen — not for secondary or contextual actions.</p>
  <hr class="s-rule" />

  <div class="sub-label">Sizes</div>
  <div class="demo">
    <div class="row" style="align-items:flex-end;gap:20px">
      <div style="text-align:center">
        <button class="fab fab--contrast fab--sm" aria-label="Add">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        </button>
        <span class="ann">sm · 40px</span>
      </div>
      <div style="text-align:center">
        <button class="fab fab--contrast" aria-label="Add">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        </button>
        <span class="ann">md · 56px</span>
      </div>
      <div style="text-align:center">
        <button class="fab fab--contrast fab--lg" aria-label="Add">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        </button>
        <span class="ann">lg · 64px</span>
      </div>
    </div>
  </div>

  <div class="sub-label">Colour variants</div>
  <div class="demo">
    <div class="row" style="gap:16px;align-items:center">
      <button class="fab fab--contrast" aria-label="Contrast">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      </button>
      <button class="fab fab--surface" aria-label="Surface">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      </button>
      <div style="background:var(--fill-neutral-hard-enabled);padding:16px;border-radius:16px;display:flex;gap:12px">
        <button class="fab fab--surface" aria-label="On dark surface">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        </button>
      </div>
    </div>
    <div style="margin-top:8px;display:flex;gap:48px">
      <span class="ann">contrast</span>
      <span class="ann" style="margin-left:4px">surface</span>
      <span class="ann" style="margin-left:20px">surface on dark</span>
    </div>
  </div>

  <div class="sub-label">Extended (with label)</div>
  <div class="demo">
    <div class="row" style="gap:12px;flex-wrap:wrap">
      <button class="fab fab--contrast fab--extended">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Start ride
      </button>
      <button class="fab fab--surface fab--extended">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"/></svg>
        Open map
      </button>
    </div>
  </div>

  <div class="sub-label" style="margin-top:40px">Code</div>
  <div class="code-block"><pre><span class="c-comment">/* Icon FAB */</span>
<span class="c-tag">&lt;button</span> <span class="c-attr">class</span>=<span class="c-str">"fab fab--contrast"</span> <span class="c-attr">aria-label</span>=<span class="c-str">"Add"</span><span class="c-tag">&gt;</span>
  <span class="c-comment">&lt;!-- 24px icon --&gt;</span>
<span class="c-tag">&lt;/button&gt;</span>

<span class="c-comment">/* Extended with label */</span>
<span class="c-tag">&lt;button</span> <span class="c-attr">class</span>=<span class="c-str">"fab fab--contrast fab--extended"</span><span class="c-tag">&gt;</span>
  <span class="c-comment">&lt;!-- icon --&gt;</span>
  Start ride
<span class="c-tag">&lt;/button&gt;</span>

<span class="c-comment">/* Sizes: fab--sm (40px) · default (56px) · fab--lg (64px) */</span>
<span class="c-comment">/* Variants: fab--contrast · fab--accent · fab--surface */</span></pre></div>

  <div class="sub-label" style="margin-top:40px">Anatomy</div>
  <table class="prop-table">
    <thead><tr><th>Token</th><th>Value</th><th>Note</th></tr></thead>
    <tbody>
      <tr><td><code>Default size</code></td><td><code>56×56px, 16px radius</code></td><td>Material spec "regular FAB"</td></tr>
      <tr><td><code>Shadow</code></td><td><code>--shadow-deep</code></td><td>Elevates above page content</td></tr>
      <tr><td><code>Hover lift</code></td><td><code>translateY(-2px) + deeper shadow</code></td><td>Signals interactivity on hover</td></tr>
      <tr><td><code>Contrast fill</code></td><td><code>Tire (#282425)</code></td><td>Primary action — never Coral</td></tr>
      <tr><td><code>Surface fill</code></td><td><code>--surface-raised-enabled (white)</code></td><td>Sits cleanly over map/image backgrounds</td></tr>
      <tr><td><code>Position</code></td><td><code>Bottom-right, 16px from edges</code></td><td>Above bottom nav when present (mb: 96px)</td></tr>
    </tbody>
  </table>
</BaseLayout>
