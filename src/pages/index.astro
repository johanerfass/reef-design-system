---
import BaseLayout from '../layouts/BaseLayout.astro';
const VOI_LOGO_PATH = "M58.6932 23.8032L36.9976 75.2173H21.607L0 23.8032H15.3906L29.63 58.7818L44.3476 23.8032H58.6932ZM92.6092 75.9789C87.1897 75.9789 82.337 74.8454 78.0333 72.5784C73.8713 70.4354 70.3646 67.1767 67.9559 63.1563C65.5296 59.136 64.3252 54.5844 64.3252 49.4837C64.3252 44.383 65.5296 39.8313 67.9559 35.811C70.3823 31.7907 73.8713 28.5319 78.0333 26.3889C82.337 24.122 87.1897 22.9885 92.6092 22.9885C98.0287 22.9885 102.864 24.122 107.132 26.3889C111.276 28.5496 114.748 31.8084 117.174 35.811C119.6 39.8313 120.805 44.383 120.805 49.4837C120.805 54.5844 119.6 59.136 117.174 63.1563C114.765 67.1589 111.294 70.4177 107.15 72.5784C102.881 74.8454 98.0287 75.9789 92.6092 75.9789ZM92.6092 63.7408C96.4347 63.7408 99.5695 62.4479 102.031 59.8621C104.475 57.2764 105.715 53.8228 105.715 49.4837C105.715 45.1446 104.493 41.691 102.031 39.1052C99.5695 36.5194 96.4347 35.2266 92.6092 35.2443C88.7837 35.2443 85.6312 36.5372 83.1517 39.1229C80.6722 41.7087 79.4325 45.1623 79.4325 49.5014C79.4325 53.8405 80.6722 57.2941 83.1517 59.8798C85.6312 62.4656 88.7837 63.7408 92.6092 63.7408ZM135.522 23.7855H150.435V75.2173H135.522V23.7855ZM142.978 16.6303C140.233 16.6303 138.002 15.8334 136.284 14.2394C134.601 12.734 133.663 10.5733 133.716 8.32403C133.68 6.07477 134.619 3.89635 136.301 2.39094C138.019 0.796981 140.251 0 142.978 0C145.724 0 147.955 0.76156 149.673 2.30239C151.356 3.73696 152.294 5.82682 152.259 8.04065C152.33 10.3785 151.391 12.61 149.673 14.204C147.955 15.8156 145.724 16.6303 142.978 16.6303ZM174.716 75.9789C172.236 76.032 169.863 75.0579 168.128 73.3046C166.357 71.5335 165.382 69.1248 165.453 66.6099C165.453 63.8648 166.339 61.6509 168.128 59.9684C171.882 56.5857 177.567 56.5857 181.322 59.9684C183.111 61.6509 183.996 63.8648 183.996 66.6099C184.067 69.1071 183.093 71.5335 181.322 73.3046C179.569 75.0579 177.178 76.032 174.716 75.9789Z";
---

<BaseLayout title="Overview">

  <!-- ─── HERO ────────────────────────────────────────────────────────── -->
  <div class="voi-hero-bg hero" id="hero-bg">
    <div class="voi-orb voi-orb--coral-a"></div>
    <div class="voi-orb voi-orb--coral-b"></div>
    <div class="voi-orb voi-orb--coral-c"></div>
    <div class="voi-orb voi-orb--coral-d"></div>
    <div class="voi-orb voi-orb--coral-e"></div>
    <div class="voi-orb voi-orb--sky-a"></div>
    <div class="voi-orb voi-orb--sky-b"></div>
    <div class="voi-orb voi-orb--sky-c"></div>
    <div class="voi-orb voi-orb--sky-d"></div>
    <div class="hero-content">
      <div class="hero-kicker">Reef design system · v1.3.2</div>
      <h1>Design<br>in <em>Voi's</em><br>language.</h1>
      <p class="hero-sub">35 components, 80+ tokens, and one golden rule. Every building block for Voi's digital products — in one place.</p>
      <div class="hero-btns">
        <a href="/foundation/colours" class="btn btn-contrast btn-lg">Explore tokens</a>
        <a href="/components/buttons" class="btn btn-outlined btn-lg">View components</a>
      </div>
    </div>
    <div class="hero-photo-wrap">
      <div class="hero-photo">
        <img src="https://media.ffycdn.net/eu/voi-technologies/eyJwYXRoIjoidm9pLXRlY2hub2xvZ2llc1wvYWNjb3VudHNcL2YxXC80MDAxMTMzXC9wcm9qZWN0c1wvMjFcL2Fzc2V0c1wvYTdcLzE1MzAyXC9lZDZhMWYxNzExOGFkOGQzNjM5N2RhOTg4OGYxNzZjMy0xNjQyNzc1MTE4LmpwZyJ9:voi-technologies:NzCV0vYqN4HwSUE-_Evr_hWx9Xxl9FKWKw3zKEX-dx0?mod=v1/resize=2400" alt="Two riders with Voi e-scooters in Stockholm" loading="eager" />
      </div>
      <div class="hero-badge">
        <img class="hero-badge-app-icon" src="/voi-app-icon.png" alt="Voi app icon" width="48" height="48" />
        <div>
          <div class="hero-badge-title">Voi rider app</div>
          <div class="hero-badge-sub">★ 4.8 · Free · iOS &amp; Android</div>
        </div>
      </div>
    </div>
  </div>

  <!-- ─── STATS STRIP ─────────────────────────────────────────────────── -->
  <div class="stats-strip anim">
    <div class="stat-item">
      <span class="stat-number" data-count="35">35</span>
      <span class="stat-label">Components</span>
    </div>
    <div class="stat-divider"></div>
    <div class="stat-item">
      <span class="stat-number" data-count="80" data-suffix="+">80+</span>
      <span class="stat-label">Design tokens</span>
    </div>
    <div class="stat-divider"></div>
    <div class="stat-item">
      <span class="stat-number" data-count="3">3</span>
      <span class="stat-label">Platforms</span>
    </div>
    <div class="stat-divider"></div>
    <div class="stat-item">
      <span class="stat-number" data-count="1">1</span>
      <span class="stat-label">Golden rule</span>
    </div>
  </div>

  <!-- ─── SPOTLIGHT 1: COMPONENTS ─────────────────────────────────────── -->
  <div class="section-gap anim">
    <div class="feat">
      <div class="feat-copy">
        <div class="s-overline">Components</div>
        <h2 class="feat-heading">35 components.<br>Production-ready.</h2>
        <p class="feat-body">Every component is interactive, token-driven, and dark-mode aware. What you see here is exactly what ships — no extra translation needed.</p>
        <a href="/components/buttons" class="btn btn-outlined btn-sm">Browse all components</a>
      </div>
      <div class="feat-visual">
        <div class="feat-frame--bento">

          <!-- Live Activity card (full width) -->
          <div class="bento-card bento-card--live">
            <div class="bento-label">Live activity · Dynamic Island</div>
            <div class="la-widget">
              <div class="la-left">
                <svg class="la-logo" viewBox="0 0 184 76" fill="#F26961" aria-label="Voi"><path d={VOI_LOGO_PATH} /></svg>
                <div class="la-meta">
                  <span class="la-meta-item">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2C8 2 5 6 5 10c0 6 7 12 7 12s7-6 7-12c0-4-3-8-7-8z"/><circle cx="12" cy="10" r="2.5"/></svg>
                    XC23
                  </span>
                  <span class="la-meta-sep">·</span>
                  <span class="la-meta-item">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="16" height="10" rx="2"/><path d="M20 10v4" stroke-width="2.5"/></svg>
                    Almost full
                  </span>
                </div>
              </div>
              <div class="la-right">
                <span class="la-badge">Riding</span>
                <span class="la-timer" id="la-timer">00:01</span>
              </div>
            </div>
          </div>

          <!-- Buttons card (full width) -->
          <div class="bento-card bento-card--full">
            <div class="bento-label">Buttons · 4 variants</div>
            <div class="bento-btn-row">
              <button class="btn btn-contrast btn-sm">Start ride</button>
              <button class="btn btn-outlined btn-sm">End ride</button>
              <button class="btn btn-transparent btn-sm">Learn more</button>
              <button class="btn btn-accent btn-sm">Voi+</button>
            </div>
          </div>

          <!-- Badges card -->
          <div class="bento-card bento-card--badges">
            <div class="bento-label">Badges</div>
            <div class="bento-badge-stack">
              <span class="badge badge-success">Available</span>
              <span class="badge badge-warning">Low battery</span>
              <span class="badge badge-information">Charging</span>
              <span class="badge badge-contrast">Out of zone</span>
            </div>
          </div>

          <!-- Toggles card -->
          <div class="bento-card bento-card--toggles">
            <div class="bento-label">Toggles</div>
            <div style="display:flex;flex-direction:column;gap:10px;margin-top:4px">
              <label class="bento-toggle-row">
                <span class="toggle toggle-sm"><input type="checkbox" checked><div class="toggle-track"></div></span>
                <span class="bento-toggle-label">Notifications</span>
              </label>
              <label class="bento-toggle-row">
                <span class="toggle toggle-sm"><input type="checkbox"><div class="toggle-track"></div></span>
                <span class="bento-toggle-label" style="color:var(--content-body-secondary)">Safe parking</span>
              </label>
              <label class="bento-toggle-row">
                <span class="toggle toggle-sm"><input type="checkbox" disabled><div class="toggle-track"></div></span>
                <span class="bento-toggle-label" style="color:var(--content-body-tertiary)">Night mode</span>
              </label>
            </div>
          </div>

          <!-- Tabs card (full width) -->
          <div class="bento-card bento-card--tabs">
            <div class="bento-label">Tabs · 2 styles</div>
            <div style="display:flex;flex-direction:column;gap:12px;margin-top:4px">
              <div class="tabs">
                <button class="tab active">Nearby</button>
                <button class="tab">My rides</button>
                <button class="tab">Wallet</button>
              </div>
              <div class="tabs tabs--pill">
                <button class="tab active">All</button>
                <button class="tab">E-bikes</button>
                <button class="tab">Scooters</button>
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </div>

  <!-- ─── GOLDEN RULE STATEMENT ────────────────────────────────────────── -->
  <div class="section-gap anim">
    <div class="golden-statement">
      <div class="golden-statement-kicker">The golden rule</div>
      <h2 class="golden-statement-heading">Coral is the brand.<br>Tire runs the UI.</h2>
      <p class="golden-statement-body">Logos, hero moments, and marketing accents — coral's territory. Every interactive element uses Tire. One rule that keeps every screen calm and premium.</p>
      <div class="golden-brand-demo">
        <div class="golden-brand-item">
          <span class="golden-brand-label">Logo</span>
          <svg class="golden-voi-logo" viewBox="0 0 184 76" fill="#F26961" aria-label="Voi" role="img"><path d={VOI_LOGO_PATH} /></svg>
        </div>
        <div class="golden-brand-divider"></div>
        <div class="golden-brand-item">
          <span class="golden-brand-label">Brand moments</span>
          <div class="golden-brand-headline">Move<br>free.</div>
        </div>
        <div class="golden-brand-divider"></div>
        <div class="golden-brand-item">
          <span class="golden-brand-label">Every action</span>
          <div style="display:flex;flex-direction:column;gap:8px">
            <button class="btn btn-contrast btn-sm">Start ride</button>
            <button class="btn btn-outlined btn-sm">End ride</button>
          </div>
          <span class="golden-brand-sublabel">Always Tire</span>
        </div>
      </div>
    </div>
  </div>

  <!-- ─── BRAND ASSETS ──────────────────────────────────────────────────── -->
  <div class="section-gap anim">
    <div class="feat feat--rev">
      <div class="feat-visual">
        <div class="assets-mosaic">
          <img class="assets-photo assets-photo--a" src="https://media.ffycdn.net/eu/voi-technologies/eyJvYXV0aCI6eyJjbGllbnRfaWQiOiJmcm9udGlmeS1tY3AifSwicGF0aCI6InZvaS10ZWNobm9sb2dpZXNcL2FjY291bnRzXC9mMVwvNDAwMTEzM1wvcHJvamVjdHNcLzIxXC9hc3NldHNcL2I5XC8xNTEzNlwvMTA4YWUxYmFkMTQzZmU1YzVlMDM0OTMyZjBlN2NjNzktMTY0Mjc3MzU0MC5qcGcifQ:voi-technologies:xqXvNPg3rdbVZrJAoA73_Pubz8HtrzmTWd00tfPHwBQ?cid=frontify-mcp" alt="Voi riders in Stockholm" loading="lazy" />
          <img class="assets-photo assets-photo--b" src="https://media.ffycdn.net/eu/voi-technologies/RdHVJY3ZseUnMnjKa6LQ.jpg?cid=frontify-mcp" alt="Voi rider on scooter" loading="lazy" />
          <img class="assets-photo assets-photo--c" src="https://media.ffycdn.net/eu/voi-technologies/yDRNLTBwbZMTZNvQHyHs.png?cid=frontify-mcp" alt="Voi illustration — e-bike rider" loading="lazy" />
          <img class="assets-photo assets-photo--d" src="https://media.ffycdn.net/eu/voi-technologies/MfLyuvLhQtTjC7iooTae.png?cid=frontify-mcp" alt="Voi illustration — two riders in city" loading="lazy" />
        </div>
      </div>
      <div class="feat-copy">
        <div class="s-overline">Brand assets</div>
        <h2 class="feat-heading">Every asset.<br>One source.</h2>
        <p class="feat-body">Photography, illustrations, and icons all live in Frontify — approved files served straight from CDN. No downloads, no stale copies.</p>
        <div class="assets-icons-strip">
          <div class="assets-icon-chip">
            <img src="https://media.ffycdn.net/eu/voi-technologies/TBMAv2MdEb9aY17HEBYD.svg?cid=frontify-mcp" width="20" height="20" alt="scooter icon" />
          </div>
          <div class="assets-icon-chip">
            <img src="https://media.ffycdn.net/eu/voi-technologies/p4NgmxHo4Hqmz7WfHwEv.svg?cid=frontify-mcp" width="20" height="20" alt="map-pin icon" />
          </div>
          <div class="assets-icon-chip">
            <img src="https://media.ffycdn.net/eu/voi-technologies/45JctX59SZ5vxR9344pR.svg?cid=frontify-mcp" width="20" height="20" alt="map icon" />
          </div>
          <div class="assets-icon-chip">
            <img src="https://media.ffycdn.net/eu/voi-technologies/xCDvq2QuUi9AEYSFCBgM.svg?cid=frontify-mcp" width="20" height="20" alt="helmet icon" />
          </div>
          <div class="assets-icon-chip">
            <img src="https://media.ffycdn.net/eu/voi-technologies/Y9eanQP5KfVSRGdZuz6N.svg?cid=frontify-mcp" width="20" height="20" alt="gps icon" />
          </div>
          <div class="assets-icon-count">800+ icons</div>
        </div>
        <div class="assets-cdn-chip">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
          <span>media.ffycdn.net/eu/voi-technologies/…</span>
        </div>
        <a href="https://brand.voi.com" target="_blank" rel="noopener" class="btn btn-outlined btn-sm" style="margin-top:24px">Browse Frontify</a>
      </div>
    </div>
  </div>

  <!-- ─── QUICK NAV ────────────────────────────────────────────────────── -->
  <div class="section-gap anim">
    <div class="s-overline">Explore</div>
    <h2 class="showcase-heading">Where do you want to go?</h2>
    <div class="grid-auto" style="margin-top:32px">
      <a href="/foundation/colours" class="nav-card">
        <div class="nav-card-thumb nav-card-thumb--foundation" style="background:linear-gradient(135deg,#F2F2F6 0%,#e8e4df 100%)">
          <div style="display:flex;gap:6px">
            <div style="width:20px;height:20px;border-radius:50%;background:#F26961"></div>
            <div style="width:20px;height:20px;border-radius:50%;background:#282425"></div>
            <div style="width:20px;height:20px;border-radius:50%;background:#ABD1EA"></div>
          </div>
        </div>
        <div class="nav-card-body">
          <div class="nav-card-title">Foundation</div>
          <div class="nav-card-desc">Colours, type, spacing, shadows & radius</div>
        </div>
        <svg class="nav-card-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
      <a href="/components/buttons" class="nav-card">
        <div class="nav-card-thumb" style="background:linear-gradient(135deg,#282425 0%,#585455 100%)">
          <div style="display:flex;gap:6px">
            <div style="padding:4px 10px;border-radius:6px;background:#fff;font-size:9px;font-weight:700;color:#282425;font-family:'Sora',sans-serif">Btn</div>
            <div style="padding:4px 10px;border-radius:6px;border:1.5px solid rgba(255,255,255,.5);font-size:9px;font-weight:700;color:#fff;font-family:'Sora',sans-serif">Btn</div>
          </div>
        </div>
        <div class="nav-card-body">
          <div class="nav-card-title">Components</div>
          <div class="nav-card-desc">35 components across all platforms</div>
        </div>
        <svg class="nav-card-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
      <a href="/patterns/dos-donts" class="nav-card">
        <div class="nav-card-thumb" style="background:linear-gradient(135deg,#ABD1EA 0%,#243860 100%)">
          <div style="display:flex;gap:8px">
            <div style="width:28px;height:28px;border-radius:50%;background:rgba(255,255,255,.25);display:flex;align-items:center;justify-content:center">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <div style="width:28px;height:28px;border-radius:50%;background:rgba(255,255,255,.15);display:flex;align-items:center;justify-content:center">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </div>
          </div>
        </div>
        <div class="nav-card-body">
          <div class="nav-card-title">Patterns</div>
          <div class="nav-card-desc">Dos & don'ts, voice & tone</div>
        </div>
        <svg class="nav-card-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
      <a href="/tooling/atmospheres" class="nav-card">
        <div class="nav-card-thumb" style="background:radial-gradient(ellipse at 20% 80%,rgba(242,105,97,.35) 0%,transparent 60%),radial-gradient(ellipse at 80% 20%,rgba(171,209,234,.4) 0%,transparent 60%),#faf4ec">
        </div>
        <div class="nav-card-body">
          <div class="nav-card-title">Tooling</div>
          <div class="nav-card-desc">Atmospheres, Claude Code skill</div>
        </div>
        <svg class="nav-card-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>
  </div>

  <!-- ─── RESOURCES ────────────────────────────────────────────────────── -->
  <div class="section-gap anim">
    <div class="s-overline">Resources</div>
    <h2 class="showcase-heading">Go to the source.</h2>
    <p class="s-desc" style="margin-bottom:32px;max-width:480px">Reef is a personal reference — these are the official Voi brand and design files.</p>
    <div class="grid-2" style="gap:12px">
      <a href="https://brand.voi.com/hub/3" target="_blank" rel="noopener" class="resource-link">
        <div style="width:40px;height:40px;border-radius:12px;background:var(--core-tire);display:flex;align-items:center;justify-content:center;flex-shrink:0">
          <svg width="20" height="8" viewBox="0 0 184 76" fill="white"><path d="M58.7 23.8L37 75.2H21.6L0 23.8h15.4l14.2 35 14.8-35h14.3z"/></svg>
        </div>
        <div style="flex:1">
          <div style="font-size:14px;font-weight:600;color:var(--content-heading-primary)">Voi Brand Portal</div>
          <div style="font-size:12px;color:var(--content-body-tertiary);margin-top:2px">brand.voi.com · Identity, voice, assets</div>
        </div>
        <svg style="opacity:.3;flex-shrink:0" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
      </a>
      <a href="https://www.figma.com/design/M7HfjUuDwU3AtQdiijFtyR/Reef---Design-System--v.1.3.2-" target="_blank" rel="noopener" class="resource-link">
        <div style="width:40px;height:40px;border-radius:12px;background:#0d99ff;display:flex;align-items:center;justify-content:center;flex-shrink:0">
          <svg width="18" height="27" viewBox="0 0 38 57" fill="white"><path d="M19 28.5a9.5 9.5 0 1 1 19 0 9.5 9.5 0 0 1-19 0z"/><path d="M0 47.5A9.5 9.5 0 0 1 9.5 38H19v9.5a9.5 9.5 0 0 1-19 0z"/><path d="M19 0v19h9.5a9.5 9.5 0 0 0 0-19H19z"/><path d="M0 9.5A9.5 9.5 0 0 0 9.5 19H19V0H9.5A9.5 9.5 0 0 0 0 9.5z"/><path d="M0 28.5A9.5 9.5 0 0 0 9.5 38H19V19H9.5A9.5 9.5 0 0 0 0 28.5z"/></svg>
        </div>
        <div style="flex:1">
          <div style="font-size:14px;font-weight:600;color:var(--content-heading-primary)">Reef in Figma</div>
          <div style="font-size:12px;color:var(--content-body-tertiary);margin-top:2px">v1.3.2 · Component specs, design tokens</div>
        </div>
        <svg style="opacity:.3;flex-shrink:0" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
      </a>
    </div>
  </div>

</BaseLayout>

<script>
// ─── SCROLL ANIMATIONS + COUNT-UP ───────────────────────────────────────
(function () {
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // Intersection observer — reveal .anim elements
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      entry.target.classList.add('anim--visible');
      // Trigger count-up for stat numbers inside this element
      entry.target.querySelectorAll('[data-count]').forEach(el => {
        if (el.dataset.counted) return;
        el.dataset.counted = '1';
        const target = parseInt(el.dataset.count, 10);
        const suffix = el.dataset.suffix || '';
        if (reduced) { el.textContent = target + suffix; return; }
        const duration = 900;
        const start = performance.now();
        const tick = (now: number) => {
          const p = Math.min((now - start) / duration, 1);
          const ease = 1 - Math.pow(1 - p, 3);
          el.textContent = Math.round(ease * target) + suffix;
          if (p < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      });
      observer.unobserve(entry.target);
    });
  }, { threshold: 0.15 });

  document.querySelectorAll('.anim').forEach(el => {
    if (reduced) { el.classList.add('anim--visible'); return; }
    observer.observe(el);
  });
})();

// ─── ORB REACTIVITY ─────────────────────────────────────────────────────
(function () {
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
  const hero = document.getElementById('hero-bg');
  if (!hero) return;
  const orbs = [...hero.querySelectorAll('.voi-orb')] as HTMLElement[];
  const factors = [0.10, -0.07, 0.15, -0.09, 0.12, -0.06, 0.13, -0.10, 0.08];
  const scatter = orbs.map(() => ({ x: 0, y: 0 }));
  let targetX = 0, targetY = 0, currentX = 0, currentY = 0, active = false;

  function onPointer(e: MouseEvent | TouchEvent) {
    const r = hero.getBoundingClientRect();
    const clientX = 'touches' in e ? (e as TouchEvent).touches[0].clientX : (e as MouseEvent).clientX;
    const clientY = 'touches' in e ? (e as TouchEvent).touches[0].clientY : (e as MouseEvent).clientY;
    targetX = clientX - (r.left + r.width / 2);
    targetY = clientY - (r.top + r.height / 2);
    active = true;
  }
  function onLeave() { targetX = 0; targetY = 0; active = false; }
  function onClick(e: MouseEvent) {
    const r = hero.getBoundingClientRect();
    const cx = e.clientX - (r.left + r.width / 2);
    const cy = e.clientY - (r.top + r.height / 2);
    orbs.forEach((_, i) => {
      const angle = (i / orbs.length) * Math.PI * 2 + Math.random() * 0.4;
      const radius = 120 + Math.random() * 80;
      scatter[i].x = Math.cos(angle) * radius - cx * 0.15;
      scatter[i].y = Math.sin(angle) * radius - cy * 0.15;
    });
  }
  hero.addEventListener('mousemove', onPointer as EventListener, { passive: true });
  hero.addEventListener('touchstart', onPointer as EventListener, { passive: true });
  hero.addEventListener('touchmove', onPointer as EventListener, { passive: true });
  hero.addEventListener('mouseleave', onLeave);
  hero.addEventListener('touchend', onLeave);
  hero.addEventListener('click', onClick as EventListener);

  function tick() {
    const speed = active ? 0.04 : 0.025;
    currentX += (targetX - currentX) * speed;
    currentY += (targetY - currentY) * speed;
    orbs.forEach((orb, i) => {
      scatter[i].x *= 0.92;
      scatter[i].y *= 0.92;
      const f = factors[i % factors.length];
      orb.style.setProperty('--rx', `${(currentX * f + scatter[i].x).toFixed(2)}px`);
      orb.style.setProperty('--ry', `${(currentY * f + scatter[i].y).toFixed(2)}px`);
    });
    requestAnimationFrame(tick);
  }
  tick();
})();

// ─── LIVE ACTIVITY TIMER ────────────────────────────────────────────────
(function () {
  const el = document.getElementById('la-timer');
  if (!el) return;
  let secs = 1;
  setInterval(() => {
    secs++;
    const m = String(Math.floor(secs / 60)).padStart(2, '0');
    const s = String(secs % 60).padStart(2, '0');
    el.textContent = `${m}:${s}`;
  }, 1000);
})();

</script>

