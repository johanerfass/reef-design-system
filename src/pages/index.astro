        <img src="https://media.ffycdn.net/eu/voi-technologies/eyJwYXRoIjoidm9pLXRlY2hub2xvZ2llc1wvYWNjb3VudHNcL2YxXC80MDAxMTMzXC9wcm9qZWN0c1wvMjFcL2Fzc2V0c1wvYTdcLzE1MzAyXC9lZDZhMWYxNzExOGFkOGQzNjM5N2RhOTg4OGYxNzZjMy0xNjQyNzc1MTE4LmpwZyJ9:voi-technologies:NzCV0vYqN4HwSUE-_Evr_hWx9Xxl9FKWKw3zKEX-dx0?mod=v1/resize=2400" alt="Two riders with Voi e-scooters in Stockholm" loading="eager" />
      </div>
      <div class="hero-badge">
        <img class="hero-badge-app-icon" src="/voi-app-icon.png" alt="Voi app icon" width="48" height="48" />
        <div>
          <div class="hero-badge-title">Voi rider app</div>
          <div class="hero-badge-sub">★ 4.8 · Free · iOS &amp; Android</div>
        </div>
      </div>
    </div>
  </div>

  <!-- ─── STATS STRIP ─────────────────────────────────────────────────── -->
  <div class="stats-strip anim">
    <div class="stat-item">
      <span class="stat-number" data-count="35">35</span>
      <span class="stat-label">Components</span>
    </div>
    <div class="stat-divider"></div>
    <div class="stat-item">
      <span class="stat-number" data-count="80" data-suffix="+">80+</span>
      <span class="stat-label">Design tokens</span>
    </div>
    <div class="stat-divider"></div>
    <div class="stat-item">
      <span class="stat-number" data-count="3">3</span>
      <span class="stat-label">Platforms</span>
    </div>
    <div class="stat-divider"></div>
    <div class="stat-item">
      <span class="stat-number" data-count="1">1</span>
      <span class="stat-label">Golden rule</span>
