<script>
// ─── SCROLL ANIMATIONS + COUNT-UP ───────────────────────────────────────
(function () {
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // Intersection observer — reveal .anim elements
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      entry.target.classList.add('anim--visible');
      // Trigger count-up for stat numbers inside this element
      entry.target.querySelectorAll('[data-count]').forEach(el => {
        if (el.dataset.counted) return;
        el.dataset.counted = '1';
        const target = parseInt(el.dataset.count, 10);
        const suffix = el.dataset.suffix || '';
        if (reduced) { el.textContent = target + suffix; return; }
        const duration = 900;
        const start = performance.now();
        const tick = (now: number) => {
          const p = Math.min((now - start) / duration, 1);
          const ease = 1 - Math.pow(1 - p, 3);
          el.textContent = Math.round(ease * target) + suffix;
          if (p < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      });
      observer.unobserve(entry.target);
    });
  }, { threshold: 0.15 });

  document.querySelectorAll('.anim').forEach(el => {
    if (reduced) { el.classList.add('anim--visible'); return; }
    observer.observe(el);
  });
})();

// ─── ORB REACTIVITY ─────────────────────────────────────────────────────
(function () {
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
  const hero = document.getElementById('hero-bg');
  if (!hero) return;
  const orbs = [...hero.querySelectorAll('.voi-orb')] as HTMLElement[];
  const factors = [0.10, -0.07, 0.15, -0.09, 0.12, -0.06, 0.13, -0.10, 0.08];
  const scatter = orbs.map(() => ({ x: 0, y: 0 }));
  let targetX = 0, targetY = 0, currentX = 0, currentY = 0, active = false;

  function onPointer(e: MouseEvent | TouchEvent) {
    const r = hero.getBoundingClientRect();
    const clientX = 'touches' in e ? (e as TouchEvent).touches[0].clientX : (e as MouseEvent).clientX;
    const clientY = 'touches' in e ? (e as TouchEvent).touches[0].clientY : (e as MouseEvent).clientY;
    targetX = clientX - (r.left + r.width / 2);
    targetY = clientY - (r.top + r.height / 2);
    active = true;
  }
  function onLeave() { targetX = 0; targetY = 0; active = false; }
  function onClick(e: MouseEvent) {
    const r = hero.getBoundingClientRect();
    const cx = e.clientX - (r.left + r.width / 2);
    const cy = e.clientY - (r.top + r.height / 2);
    orbs.forEach((_, i) => {
      const angle = (i / orbs.length) * Math.PI * 2 + Math.random() * 0.4;
      const radius = 120 + Math.random() * 80;
      scatter[i].x = Math.cos(angle) * radius - cx * 0.15;
      scatter[i].y = Math.sin(angle) * radius - cy * 0.15;
    });
  }
  hero.addEventListener('mousemove', onPointer as EventListener, { passive: true });
  hero.addEventListener('touchstart', onPointer as EventListener, { passive: true });
  hero.addEventListener('touchmove', onPointer as EventListener, { passive: true });
  hero.addEventListener('mouseleave', onLeave);
  hero.addEventListener('touchend', onLeave);
  hero.addEventListener('click', onClick as EventListener);

  function tick() {
    const speed = active ? 0.04 : 0.025;
    currentX += (targetX - currentX) * speed;
    currentY += (targetY - currentY) * speed;
    orbs.forEach((orb, i) => {
      scatter[i].x *= 0.92;
      scatter[i].y *= 0.92;
      const f = factors[i % factors.length];
      orb.style.setProperty('--rx', `${(currentX * f + scatter[i].x).toFixed(2)}px`);
      orb.style.setProperty('--ry', `${(currentY * f + scatter[i].y).toFixed(2)}px`);
    });
    requestAnimationFrame(tick);
  }
  tick();
})();

</script>

<style>
/* ─── HERO ──────────────────────────────────────────────────────────── */
