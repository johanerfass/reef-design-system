    <div class="voi-orb voi-orb--coral-c"></div>
    <div class="voi-orb voi-orb--coral-d"></div>
    <div class="voi-orb voi-orb--coral-e"></div>
    <div class="voi-orb voi-orb--sky-a"></div>
    <div class="voi-orb voi-orb--sky-b"></div>
    <div class="voi-orb voi-orb--sky-c"></div>
    <div class="voi-orb voi-orb--sky-d"></div>
